@model KenalPhihsing.Models.Module
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Urus Kandungan Modul";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Kandungan: @Model.Title</h2>
            <span class="badge bg-dark">Kategori: @Model.Category</span>
        </div>
        <a href="@Url.Action("EditPage", "Admin", new { moduleId = Model.Id })" class="btn btn-primary rounded-pill px-4">
            <ion-icon name="add-circle-outline" class="me-1 align-middle"></ion-icon> Tambah Halaman Baru
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <table class="table table-hover mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">M/S</th>
                    <th>Tajuk Halaman</th>
                    <th>Jenis</th>
                    <th class="text-center">Tindakan</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Pages.OrderBy(x => x.PageNumber))
                {
                    <tr>
                        <td class="ps-4">@p.PageNumber</td>
                        <td>@p.PageTitle</td>
                        <td>
                            @if (p.PageType == "Content")
                            {<span class="badge bg-info">Nota</span> }
                            else if (p.PageType == "Simulation")
                            { <span class="badge bg-danger">Simulasi</span> }
                            else
                            { <span class="badge bg-primary">Kuiz</span>}
                        </td>
                        <td class="text-center">
                            <a href="@Url.Action("EditPage", "Admin", new { id = p.Id, moduleId = Model.Id })" class="btn btn-sm btn-outline-dark">Sunting</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
