@model IEnumerable<KenalPhishing.Models.User>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Senarai Pelajar";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Senarai Pelajar</h2>
            <p class="text-muted small">Urus dan pantau maklumat pengguna sistem.</p>
        </div>
        <div class="text-end">
            <span class="badge bg-primary px-3 py-2 rounded-pill">Jumlah: @Model.Count() Pelajar</span>
        </div>
    </div>

    <!-- Bahagian Tapis (Filter) -->
    <div class="card border-0 shadow-sm rounded-4 p-3 mb-4">
        <div class="row align-items-center">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-0"><ion-icon name="filter-outline"></ion-icon></span>
                    <select id="categoryFilter" class="form-select border-0 bg-light rounded-3">
                        <option value="all">Semua Kategori</option>
                        <option value="Adult">Dewasa (Adult)</option>
                        <option value="Child">Kanak-Kanak (Child)</option>
                        <option value="Elder">Warga Emas (Elder)</option>
                    </select>
                </div>
            </div>
            <div class="col-md-8 text-md-end mt-2 mt-md-0">
                <small class="text-muted italic">* Gunakan menu di atas untuk menapis senarai dengan pantas.</small>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="userTable">
                <thead class="bg-dark text-white">
                    <tr>
                        <th class="ps-4" style="width: 50px;">#</th>
                        <th>Nama Pelajar</th>
                        <th>E-mel</th>
                        <th>Kategori</th>
                        <th class="text-center pe-4">Tindakan</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var user in Model)
                    {
                        <tr class="user-row" data-category="@user.Category">
                            <td class="ps-4 text-muted">@i.</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-light rounded-circle d-flex align-items-center justify-content-center me-3" style="width:35px; height:35px; border: 1px solid #eee;">
                                        @if (!string.IsNullOrEmpty(user.ProfilePicture))
                                        {
                                            <img src="~/Uploads/Profiles/@user.ProfilePicture" class="rounded-circle" style="width:100%; height:100%; object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <ion-icon name="person-outline"></ion-icon>
                                        }
                                    </div>
                                    <span class="fw-bold">@user.FullName</span>
                                </div>
                            </td>
                            <td class="text-muted">@user.Email</td>
                            <td>
                                @if (user.Category == "Elder")
                                {<span class="badge bg-warning text-dark">Warga Emas</span> }
                                else if (user.Category == "Child")
                                { <span class="badge bg-success">Kanak-Kanak</span> }
                                else
                                { <span class="badge bg-info text-white">Dewasa</span>}
                            </td>
                            <td class="text-center pe-4">
                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#userModal-@user.Id">
                                    <ion-icon name="information-circle-outline" class="align-middle me-1"></ion-icon> Profil
                                </button>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- MODAL PROFIL (Diletakkan di luar table untuk elak ralat backdrop) -->
@foreach (var user in Model)
{
    <div class="modal fade" id="userModal-@user.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 rounded-4 shadow-lg">
                <div class="modal-header border-0 bg-primary text-white p-4 rounded-top-4">
                    <h5 class="fw-bold mb-0">Maklumat Profil Pelajar</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="text-center mb-4">
                        <div class="d-inline-block p-1 rounded-circle bg-white shadow-sm mb-3">
                            @{
                                var modalPic = !string.IsNullOrEmpty(user.ProfilePicture) ? "/Uploads/Profiles/" + user.ProfilePicture : "https://ui-avatars.com/api/?name=" + user.FullName;
                            }
                            <img src="@modalPic" class="rounded-circle" style="width: 100px; height: 100px; object-fit: cover;" />
                        </div>
                        <h4 class="fw-bold mb-0">@user.FullName</h4>
                        <span class="badge bg-light text-primary border border-primary-subtle">ID Pelajar: #@user.Id</span>
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <label class="small text-muted d-block">Kategori:</label>
                            <span class="fw-bold">@user.Category</span>
                        </div>
                        <div class="col-6 text-end">
                            <label class="small text-muted d-block">Status Akaun:</label>
                            <span class="text-success fw-bold">● Aktif</span>
                        </div>
                        <hr class="my-2 opacity-25">
                        <div class="col-12">
                            <label class="small text-muted d-block"><ion-icon name="mail-outline"></ion-icon> Alamat E-mel:</label>
                            <span class="fw-bold text-dark">@user.Email</span>
                        </div>
                        <div class="col-12">
                            <label class="small text-muted d-block"><ion-icon name="call-outline"></ion-icon> No. Telefon:</label>
                            <span class="fw-bold text-dark">@(string.IsNullOrEmpty(user.Phone) ? "Tiada Maklumat" : user.Phone)</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Tutup</button>
                    <!-- Admin boleh tambah fungsi Reset Password di sini pada masa hadapan -->
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 1. Logik Penapisan (Filtering)
            const filterDropdown = document.getElementById('categoryFilter');
            const userRows = document.querySelectorAll('.user-row');

            // Sahkan filterDropdown wujud dan ia adalah elemen SELECT (hilangkan ralat TS18047 & TS2339)
            if (filterDropdown instanceof HTMLSelectElement) {
                filterDropdown.addEventListener('change', function () {
                    const selectedCategory = filterDropdown.value;

                    userRows.forEach(function(row) {
                        // Sahkan row adalah HTMLElement untuk akses .style (hilangkan ralat TS2339)
                        if (row instanceof HTMLElement) {
                            const rowCategory = row.getAttribute('data-category');

                            if (selectedCategory === "all" || rowCategory === selectedCategory) {
                                row.style.display = "";
                            } else {
                                row.style.display = "none";
                            }
                        }
                    });
                });
            }

            // 2. Fix Backdrop (Pastikan modal dipindahkan ke body)
            const modals = document.querySelectorAll('.modal');
            modals.forEach(function(modal) {
                // Sahkan modal adalah HTMLElement sebelum pindah ke body
                if (modal instanceof HTMLElement) {
                    document.body.appendChild(modal);
                }
            });
        });
    </script>
}