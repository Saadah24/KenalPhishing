@model IEnumerable<KenalPhihsing.Models.User>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Senarai Pelajar";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Senarai Pelajar</h2>
        <span class="badge bg-primary px-3 py-2 rounded-pill">Jumlah: @Model.Count() Pelajar</span>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-dark text-white">
                <tr>
                    <th class="ps-4">Nama Pelajar</th>
                    <th>E-mel</th>
                    <th>Kategori</th>
                    <th class="text-center pe-4">Tindakan</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="avatar-sm bg-light rounded-circle d-flex align-items-center justify-content-center me-3" style="width:35px; height:35px;">
                                    <ion-icon name="person-outline"></ion-icon>
                                </div>
                                <span class="fw-bold">@user.FullName</span>
                            </div>
                        </td>
                        <td>@user.Email</td>
                        <td>
                            @if (user.Category == "Elder")
                            {<span class="badge bg-warning text-dark">Warga Emas</span> }
                            else if (user.Category == "Child")
                            { <span class="badge bg-success">Kanak-Kanak</span> }
                            else
                            { <span class="badge bg-info text-white">Dewasa</span>}
                        </td>
                        <td class="text-center pe-4">
                            <!-- Contoh butang untuk Reset Password jika perlu -->
                            <button class="btn btn-sm btn-outline-secondary rounded-pill">Profil</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
