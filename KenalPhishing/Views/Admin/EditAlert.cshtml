@model KenalPhihsing.Models.SecurityAlert
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = Model.Id > 0 ? "Edit Buletin Keselamatan" : "Cipta Buletin Baru";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="@Url.Action("ManageAlerts", "Admin")" class="text-muted text-decoration-none small">
                <ion-icon name="arrow-back-outline"></ion-icon> Kembali ke Radar
            </a>
            <h3 class="fw-bold mt-2">Penyediaan Buletin Keselamatan</h3>
        </div>
        <div class="text-end">
            <span class="badge bg-dark px-3 py-2">ID LAPORAN: #SC-@(Model.Id > 0 ? Model.Id.ToString() : "BARU")</span>
        </div>
    </div>

    @using (Html.BeginForm("SaveAlert", "Admin", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)
        @Html.HiddenFor(m => m.DatePublished)

        <div class="row g-4">
            <!-- BAHAGIAN UTAMA (BULLETIN FORM) -->
            <div class="col-lg-9">
                <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                    <!-- Header Template -->
                    <div class="bg-dark p-4 text-white">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <label class="extra-small text-uppercase opacity-50 d-block mb-1">Tajuk Buletin / Taktik</label>
                                @Html.TextBoxFor(m => m.Title, new { @class = "form-control form-control-lg bg-transparent border-0 text-white fw-bold p-0", placeholder = "Masukkan Tajuk Taktik SMS/WhatsApp...", style = "font-size: 1.5rem;" })
                            </div>
                            <div class="col-md-4 text-md-end">
                                <label class="extra-small text-uppercase opacity-50 d-block mb-1">Tahap Risiko</label>
                                @Html.DropDownListFor(m => m.Severity, new SelectList(new[] { "Tinggi", "Sederhana", "Rendah" }), new { @class = "form-select form-select-sm bg-danger text-white border-0 fw-bold" })
                            </div>
                        </div>
                    </div>

                    <div class="card-body p-4 bg-light">
                        <div class="row g-4">
                            <!-- KOTAK BUKTI MESEJ (KIRI) -->
                            <div class="col-md-7">
                                <div class="p-4 bg-white border rounded-4 h-100">
                                    <h6 class="fw-bold mb-3 text-muted small"><ion-icon name="mail-unread" class="me-1"></ion-icon> [!] BUKTI MESEJ (CONTOH)</h6>
                                    @Html.TextAreaFor(m => m.ExampleMessage, new { @class = "form-control border-0 bg-light rounded-3 small", rows = "5", placeholder = "Masukkan contoh teks mesej scam di sini...", style = "font-family: 'Courier New', Courier, monospace;" })
                                    <div class="mt-2 text-danger extra-small fw-bold">* Amaran: Jangan klik pautan dalam contoh ini.</div>
                                </div>
                            </div>

                            <!-- INFO ANCAMAN (KANAN) -->
                            <div class="col-md-5">
                                <div class="p-4 bg-white border rounded-4 h-100">
                                    <h6 class="fw-bold mb-3 text-muted small"><ion-icon name="information-circle" class="me-1"></ion-icon> [ INFO ANCAMAN ]</h6>

                                    <div class="mb-3">
                                        <label class="extra-small fw-bold text-muted">IDENTITI SCAMMER (NO/LINK)</label>
                                        @Html.TextBoxFor(m => m.ScammerInfo, new { @class = "form-control form-control-sm border-0 border-bottom rounded-0 px-0", placeholder = "Contoh: 011-2345XXXX / bit.ly/bank-palsu" })
                                    </div>

                                    <div class="mb-0">
                                        <label class="extra-small fw-bold text-muted">TARIKH TERBITAN</label>
                                        <p class="mb-0 small fw-bold text-dark">@DateTime.Now.ToString("dd MMMM yyyy")</p>
                                    </div>
                                </div>
                            </div>

                            <!-- ANALISIS KESELAMATAN (BAWAH) -->
                            <div class="col-12">
                                <div class="p-4 bg-white border rounded-4">
                                    <h6 class="fw-bold mb-3 small text-primary"><ion-icon name="analytics" class="me-1"></ion-icon> ANALISIS KESELAMATAN (MODUS OPERANDI)</h6>
                                    @Html.TextAreaFor(m => m.Content, new { @class = "form-control border-0 bg-light rounded-3", rows = "6", placeholder = "Terangkan kenapa ini adalah scam dan bagaimana mangsa diperdaya..." })
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- FOOTER BUTTONS -->
                    <div class="card-footer bg-white p-4 border-0 text-center">
                        <button type="submit" class="btn btn-dark rounded-pill px-5 fw-bold shadow-sm">
                            <ion-icon name="cloud-upload-outline" class="me-2"></ion-icon> TERBITKAN BULETIN
                        </button>
                    </div>
                </div>
            </div>

            <!-- SIDEBAR TIPS -->
            <div class="col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-primary text-white mb-4">
                    <h6 class="fw-bold mb-3">Panduan Penulisan</h6>
                    <ul class="extra-small ps-3 opacity-75">
                        <li class="mb-2">Gunakan ayat yang tegas dan memberi amaran.</li>
                        <li class="mb-2">Pastikan No. Telefon Scammer diletakkan XXXX di belakang untuk privasi jika perlu.</li>
                        <li class="mb-2">Isi kandungan Analisis hendaklah mudah difahami oleh orang awam.</li>
                    </ul>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .extra-small {
        font-size: 11px;
        letter-spacing: 0.5px;
    }

    .form-control:focus, .form-select:focus {
        box-shadow: none;
        border-color: #dee2e6;
    }

    .card {
        transition: all 0.3s ease;
    }
</style>