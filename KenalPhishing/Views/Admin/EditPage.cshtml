@model KenalPhishing.Models.ModulePage

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = Model.Id > 0 ? "Sunting Halaman" : "Tambah Halaman Baharu";
}

@section Styles {
    <link href="~/Content/Admin.css" rel="stylesheet" type="text/css" />

    <style>
        /* Container for the fake mobile phone */
        .phone-container {
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100%;
        }

        .phone-shell {
            width: 320px;
            height: 520px;
            border: 12px solid #222;
            border-radius: 36px;
            background: #f4f4f5;
            overflow-y: auto;
            position: relative;
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            display: flex;
            flex-direction: column;
        }

            /* Hide scrollbars inside phone screen */
            .phone-shell::-webkit-scrollbar {
                display: none;
            }

        /* Social Media Notification Design (Lockscreen Style) */
        .notification-screen {
            background: url('https://images.unsplash.com/photo-1550684848-fac1c5b4e853?q=80&w=3270&auto=format&fit=crop') no-repeat center center;
            background-size: cover;
            flex-grow: 1;
            padding: 40px 15px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .lock-clock {
            color: white;
            text-align: center;
            margin-bottom: 20px;
            text-shadow: 0 2px 4px rgba(0,0,0,0.5);
        }

        .social-notif {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 12px;
            display: flex;
            gap: 12px;
            align-items: start;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            animation: slideDown 0.5s ease-out;
        }

        .notif-icon {
            width: 35px;
            height: 35px;
            border-radius: 8px;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .notif-content {
            flex: 1;
        }

        .notif-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2px;
        }

        .notif-title {
            font-weight: 700;
            font-size: 12px;
            color: #1a1a1a;
        }

        .notif-time {
            font-size: 10px;
            color: #666;
        }

        .notif-body {
            font-size: 11px;
            color: #333;
            line-height: 1.3;
        }

        /* WhatsApp Layout */
        .wa-header {
            background: #075E54;
            color: white;
            padding: 12px 15px;
            font-size: 14px;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .wa-body {
            background: #e5ddd5;
            flex-grow: 1;
            padding: 15px;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
        }

        .wa-bubble {
            background: #fff;
            border-radius: 8px;
            padding: 10px;
            font-size: 13px;
            max-width: 85%;
            box-shadow: 0 1px 1px rgba(0,0,0,0.1);
            position: relative;
            margin-bottom: 10px;
        }

            .wa-bubble.received {
                background: #fff;
                align-self: flex-start;
            }

        /* SMS Layout */
        .sms-header {
            background: #f4f4f5;
            border-bottom: 1px solid #e4e4e7;
            padding: 12px;
            text-align: center;
            font-size: 13px;
            font-weight: bold;
        }

        .sms-body {
            background: #ffffff;
            flex-grow: 1;
            padding: 15px;
            display: flex;
            flex-direction: column;
        }

        .sms-bubble {
            background: #e4e4e7;
            color: #000;
            padding: 10px 14px;
            border-radius: 16px;
            font-size: 13px;
            max-width: 85%;
            margin-bottom: 10px;
            align-self: flex-start;
        }

        /* E-Wallet Layout (TNG Style) */
        .ew-header {
            background: #1e3a8a; /* Deep blue */
            color: white;
            padding: 15px;
            text-align: center;
        }

        .ew-balance-card {
            background: #3b82f6;
            border-radius: 12px;
            padding: 15px;
            margin: -15px 15px 15px 15px;
            color: white;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        .ew-body {
            background: #f8fafc;
            flex-grow: 1;
            padding: 15px;
        }

        /* Antivirus Layout */
        .av-body {
            background: #7f1d1d; /* Deep Dark Red */
            color: white;
            flex-grow: 1;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .av-icon {
            font-size: 4rem;
            color: #fca5a5;
            animation: pulse 1.5s infinite;
        }

        /* USE DOUBLE @@ IN .CSHTML FILES SO ASP.NET DOESN'T THINK IT IS C# CODE */
        @@keyframes pulse {
            0% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.1);
            }

            100% {
                transform: scale(1);
            }
        }

        @@keyframes slideDown {
            from {
                transform: translateY(-20px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }
    </style>
}

<div class="container-fluid py-4">
    <div class="edit-module-card p-4 shadow-sm bg-white rounded-4 border">
        <h3 class="fw-bold mb-4">
            <ion-icon name="document-text-outline" class="align-middle me-2"></ion-icon>@ViewBag.Title
        </h3>

        @using (Html.BeginForm("SavePage", "Admin", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Id)
            @Html.HiddenFor(m => m.ModuleId)

            <!-- 1. MAKLUMAT ASAS HALAMAN -->
            <div class="row mb-4 bg-light p-3 rounded-3 border">
                <div class="col-md-4">
                    <label class="fw-bold small mb-1">Nombor Halaman (M/S)</label>
                    @Html.TextBoxFor(m => m.PageNumber, new { @class = "form-control", type = "number", required = "required" })
                </div>
                <div class="col-md-4">
                    <label class="fw-bold small mb-1">Tajuk Halaman</label>
                    @Html.TextBoxFor(m => m.PageTitle, new { @class = "form-control", required = "required", placeholder = "Cth: Kenali Pautan Palsu" })
                </div>
                <div class="col-md-4">
                    <label class="fw-bold small text-primary mb-1">Jenis Kandungan (Page Type)</label>
                    @Html.DropDownListFor(m => m.PageType, new SelectList(new[]
                    {
                        new { Value="Content", Text="Nota Pembelajaran Biasa" },
                        new { Value="Simulation", Text="Simulasi Phishing Interaktif" },
                        new { Value="Quiz", Text="Soalan Kuiz" }
                    }, "Value", "Text"), "Pilih Jenis", new { @class = "form-select", id = "pageTypeDropdown", required = "required", onchange = "toggleFormSections()" })
                </div>
            </div>

            <!-- 2. SECTION A: KANDUNGAN NOTA BIASA -->
            <div id="section-content" class="dynamic-section" style="display: none;">
                <h6 class="fw-bold text-success border-bottom pb-2"><ion-icon name="book-outline"></ion-icon> Editor Nota Pembelajaran</h6>
                <div class="mb-3">
                    <label class="form-label small fw-bold">Teks Kandungan (Boleh guna HTML)</label>
                    @Html.TextAreaFor(m => m.BodyContent, new { @class = "form-control", rows = "8", placeholder = "<p>Tulis nota di sini...</p>" })
                </div>
            </div>

            <!-- 3. SECTION B: ENJIN SIMULASI (DENGAN REAL-TIME PREVIEW) -->

            <div id="section-simulation" class="dynamic-section" style="display: none;">

                <h6 class="fw-bold text-danger border-bottom pb-2"><ion-icon name="scan-outline"></ion-icon> Tetapan Simulasi Phishing</h6>
                <div class="mb-3 bg-white p-3 border rounded">
                    <label class="fw-bold small text-danger">Pilih Tema Simulasi</label>
                    @Html.DropDownListFor(m => m.SimType, new SelectList(new[]
                    {
                        new { Value="Financial", Text="Perbankan (Maybank/CIMB)" },
                        new { Value="Social", Text="Media Sosial (IG/FB/TikTok)" },
                        new { Value="Webmail", Text="E-mel Rasmi (Gmail/Outlook)" },
                        new { Value="GovSMS", Text="Kerajaan - SMS (STR/MYGOV)" },
                        new { Value="EWallet", Text="E-Wallet (TNG/e-Wallet)" },
                        new { Value="WhatsApp", Text="Sembang WhatsApp" },
                        new { Value="SMS", Text="SMS Peranti Biasa" },
                        new { Value="Antivirus", Text="Amaran Virus (Antivirus Alert)" }
                    }, "Value", "Text"), "Pilih Jenis", new { @class = "form-select", id = "simTypeDropdown", onchange = "updatePagePreview()" })
                </div>

                <div class="row mt-3">
                    <!-- Borang Input Kiri -->
                    <div class="col-md-6">
                        <label class="small fw-bold mb-1">Nama Pengirim (Sender)</label>
                        @Html.TextBoxFor(m => m.SimSender, new { @class = "form-control mb-3", id = "inputSender", onkeyup = "updatePagePreview()", placeholder = "Cth: LHDN Support" })

                        <label class="small fw-bold mb-1">Tajuk (Subject)</label>
                        @Html.TextBoxFor(m => m.SimSubject, new { @class = "form-control mb-3", id = "inputSubject", onkeyup = "updatePagePreview()", placeholder = "Cth: Akaun anda disekat!" })

                        <label class="small fw-bold mb-1">Kandungan Mesej</label>
                        @Html.TextAreaFor(m => m.SimBody, new { @class = "form-control mb-3", id = "inputBody", rows = "4", onkeyup = "updatePagePreview()" })

                        <label class="small fw-bold mb-1 text-danger">Pautan Perangkap (Phishing Link)</label>
                        @Html.TextBoxFor(m => m.SimPhishLink, new { @class = "form-control mb-3", id = "inputLink", onkeyup = "updatePagePreview()", placeholder = "http://link-palsu.com" })

                        <label class="small fw-bold mb-1 text-primary">Klu / Hint (Keluar bila user jumpa Red Flag)</label>
                        @Html.TextBoxFor(m => m.SimClues, new { @class = "form-control mb-3", placeholder = "Cth: Perhatikan ejaan URL tersebut tidak rasmi!" })
                    </div>

                    <!-- Kotak Real-Time Preview Kanan -->
                    <div class="col-md-6">
                        <div class="card shadow-sm border-0 rounded-4 sticky-top" style="background:#f1f5f9; top: 20px;">
                            <div class="card-header bg-dark text-white rounded-top-4 small fw-bold">
                                <ion-icon name="eye-outline" class="align-middle me-1"></ion-icon> Live Preview (Pandangan Pelajar)
                            </div>

                            <div class="card-body" id="previewContainer">
                                <div id="defaultPreview" class="bg-white p-3 rounded-3 shadow-sm border">
                                    <p class="text-muted text-center small">Sila pilih tema dan isi maklumat untuk melihat preview.</p>
                                </div>
                            </div>

                            <div class="card-footer bg-white border-0 text-center pb-3">
                                <span class="badge bg-danger-subtle text-danger rounded-pill">Zon Simulasi Interaktif</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECTION C: KUIZ (TAMBAH PILIHAN JAWAPAN) -->
            <div id="section-quiz" class="dynamic-section" style="display: none;">
                <h6 class="fw-bold text-primary border-bottom pb-2">Konfigurasi Soalan Kuiz</h6>

                <div class="mb-3 mt-3">
                    <label class="small fw-bold">Soalan</label>
                    @Html.TextAreaFor(m => m.QuizQuestion, new { @class = "form-control", rows = "2" })
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="small">Pilihan A</label>
                        @Html.TextBoxFor(m => m.OptionA, new { @class = "form-control mb-2" })
                        <label class="small">Pilihan B</label>
                        @Html.TextBoxFor(m => m.OptionB, new { @class = "form-control" })
                    </div>
                    <div class="col-md-6">
                        <label class="small">Pilihan C</label>
                        @Html.TextBoxFor(m => m.OptionC, new { @class = "form-control mb-2" })
                        <label class="small">Pilihan D</label>
                        @Html.TextBoxFor(m => m.OptionD, new { @class = "form-control" })
                    </div>
                </div>

                <div class="mt-3 p-3 bg-light rounded border">
                    <label class="fw-bold text-success mb-2">Pilih Jawapan Yang Betul</label>
                    <div class="d-flex gap-4">
                        @foreach (var opt in new[] { "A", "B", "C", "D" })
                        {
                            <div class="form-check">
                                @Html.RadioButtonFor(m => m.CorrectAnswer, opt, new { @id = "correct" + opt, @class = "form-check-input" })
                                <label class="form-check-label fw-bold" for="correct@opt">Pilihan @opt</label>
                            </div>
                        }
                    </div>
                    <!-- Tambahan medan Maklum Balas di EditPage.cshtml -->
                    <div class="mt-3">
                        <label class="small fw-bold text-primary">Maklum Balas Pendidikan (Penjelasan)</label>
                        @Html.TextAreaFor(m => m.QuizFeedback, new { @class = "form-control", rows = "3", placeholder = "Cth: Tepat sekali! Agensi kerajaan tidak menggunakan Gmail..." })
                        <small class="text-muted">Penjelasan ini akan muncul selepas pelajar menjawab soalan (sama ada betul atau salah).</small>
                    </div>
                </div>
            </div>

            <!-- BUTTONS -->
            <div class="d-flex gap-2 border-top pt-4 mt-4">
                <button type="submit" class="btn btn-dark rounded-pill px-5 fw-bold shadow-sm">Simpan Halaman</button>
                <a href="@Url.Action("ManagePages", "Admin", new { moduleId = Model.ModuleId })" class="btn btn-outline-dark rounded-pill px-4">Batal</a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        let currentStep = 1;

        function resetPreviewStep() {
            currentStep = 1;
            updatePagePreview();
        }

        function goToStep2() {
            currentStep = 2;
            updatePagePreview();
        }

        function toggleFormSections() {
            var typeElem = document.getElementById("pageTypeDropdown");
            var contentSec = document.getElementById("section-content");
            var simSec = document.getElementById("section-simulation");
            var quizSec = document.getElementById("section-quiz");

            if (contentSec) contentSec.style.display = "none";
            if (simSec) simSec.style.display = "none";
            if (quizSec) quizSec.style.display = "none";

            if (typeElem instanceof HTMLSelectElement) {
                var type = typeElem.value;

                if (type === "Content" && contentSec) {
                    contentSec.style.display = "block";
                } else if (type === "Simulation" && simSec) {
                    simSec.style.display = "block";
                    updatePagePreview(); // Panggil fungsi preview baru
                } else if (type === "Quiz" && quizSec) {
                    quizSec.style.display = "block";
                }
            }
        }

        function updatePagePreview() {
            var simTypeDropdown = document.getElementById('simTypeDropdown');
            var inputSender = document.getElementById('inputSender');
            var inputSubject = document.getElementById('inputSubject');
            var inputBody = document.getElementById('inputBody');
            var inputLink = document.getElementById('inputLink');
            var container = document.getElementById('previewContainer');

            if (!container) return;

            var type = (simTypeDropdown instanceof HTMLSelectElement) ? simTypeDropdown.value : "";
            var sender = (inputSender instanceof HTMLInputElement && inputSender.value) ? inputSender.value : "Pengirim";
            var subject = (inputSubject instanceof HTMLInputElement && inputSubject.value) ? inputSubject.value : "Tajuk";
            var bodyRaw = (inputBody instanceof HTMLTextAreaElement && inputBody.value) ? inputBody.value : "Isi kandungan mesej...";

            var bodyString = bodyRaw ? String(bodyRaw) : "";
            var body = bodyString.replace(/\n/g, "<br>");

            var link = (inputLink instanceof HTMLInputElement && inputLink.value) ? inputLink.value : "http://link-palsu.com";

            var html = "";

            if (!type) {
                container.innerHTML = '<div class="bg-white p-3 rounded-3 shadow-sm border text-center"><p class="text-muted small">Sila pilih tema dan isi maklumat untuk melihat preview.</p></div>';
                return;
            }

            if (type === "SMS" || type === "WhatsApp" || type === "EWallet" || type === "GovSMS") {
                var mobileContent = "";

                if (type === "WhatsApp") {
                    mobileContent = `<div class="wa-header"><ion-icon name="logo-whatsapp" style="font-size: 18px; color: #25d366;"></ion-icon><div><div style="font-size: 12px;">${sender}</div><span style="font-size: 9px; font-weight: normal; color: #a5f3fc;">Atas Talian</span></div></div><div class="wa-body"><div class="wa-bubble received"><p class="mb-2">${body}</p><span class="text-primary text-decoration-underline fw-bold" style="font-size: 11px;">${link}</span></div></div>`;
                }
                else if (type === "SMS") {
                    mobileContent = `<div class="sms-header"><ion-icon name="person-circle-outline" style="font-size: 20px; vertical-align: middle; margin-right: 4px;"></ion-icon><span>${sender}</span></div><div class="sms-body"><div class="sms-bubble"><p class="mb-2">${body}</p><span class="text-primary text-decoration-underline fw-bold" style="font-size: 11px;">${link}</span></div></div>`;
                }
                else if (type === "GovSMS") {
                    mobileContent = `<div class="sms-header"><ion-icon name="shield-checkmark-outline" style="font-size: 20px; color: #1d4ed8; vertical-align: middle; margin-right: 4px;"></ion-icon><span>${sender}</span></div><div class="sms-body"><div class="sms-bubble" style="background-color: #eff6ff; border-left: 4px solid #1d4ed8;"><span class="badge bg-primary mb-2" style="font-size: 10px;">${subject}</span><p class="mb-2 small">${body}</p><span class="text-primary text-decoration-underline fw-bold" style="font-size: 11px;">${link}</span></div></div>`;
                }
                else if (type === "EWallet") {
                    mobileContent = `<div class="ew-header"><h6 class="fw-bold mb-0">${sender}</h6></div><div class="ew-balance-card text-start"><div class="small text-white-50" style="font-size: 10px;">Baki E-Wallet</div><h4 class="fw-bold mb-0">RM 320.50</h4></div><div class="ew-body"><div class="card p-3 shadow-sm border-0 mb-3 text-start"><h6 class="fw-bold text-danger" style="font-size: 12px;">${subject}</h6><p class="small text-muted mb-3" style="font-size: 11px;">${body}</p><button class="btn btn-primary btn-sm w-100 fw-bold" style="font-size: 11px;">${link}</button></div></div>`;
                }

                html = `<div class="phone-container"><div class="phone-shell shadow">${mobileContent}</div></div>`;
            }
            else {
                var desktopContent = "";

                if (type === "Financial") {
                    if (currentStep === 1) {
                        // Paparan Emel Bank (Langkah 1)
                        desktopContent = `
                        <div class="bg-white rounded-3 shadow-sm border overflow-hidden">
                            <div class="p-3 border-bottom bg-light d-flex align-items-center">
                                <div class="bg-primary text-white rounded-circle me-3 d-flex align-items-center justify-content-center" style="width:35px; height:35px;">
                                    <ion-icon name="mail-outline"></ion-icon>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold" style="font-size:12px;">Daripada: ${sender}</h6>
                                    <small class="text-muted" style="font-size:11px;">Subjek: ${subject}</small>
                                </div>
                            </div>
                            <div class="p-4 text-start" style="font-size:12px; min-height: 200px;">
                                <p>Pelanggan yang dihormati,</p>
                                <p>${body}</p>
                                <div class="text-center my-4">
                                    <button type="button" class="btn btn-outline-primary btn-sm fw-bold px-3" onclick="goToStep2()">Klik di sini untuk semak akaun</button>
                                    <br><small class="text-muted mt-2 d-block" style="font-size:10px;">Pautan: ${link}</small>
                                </div>
                                <p>Terima kasih,<br>${sender} Support</p>
                            </div>
                        </div>`;
                    } else {
                        // Paparan Fake Login (Langkah 2)
                        desktopContent = `
                        <div class="text-center mb-3"><div class="bg-warning p-2 d-inline-block rounded-circle mb-2"><ion-icon name="business" style="font-size: 24px;"></ion-icon></div><h5 class="fw-bold">${sender}</h5></div>
                        <div class="card p-3 mx-auto border-0 shadow-sm rounded-4" style="max-width: 300px; text-align: left;">
                            <div class="alert alert-info py-1 px-2 small mb-3 text-center" style="font-size:10px;">Sila pastikan frasa keselamatan anda betul.</div>
                            <label class="small fw-bold text-muted mb-1" style="font-size:11px;">ID Pengguna</label>
                            <input type="text" class="form-control form-control-sm mb-2 bg-light" value="pengguna_sasaran" readonly>

                            <label class="small fw-bold text-muted mb-1" style="font-size:11px;">Frasa Keselamatan Anda:</label>
                            <div class="text-center p-2 border rounded bg-light mb-3"><span class="text-danger fw-bold" style="font-size:14px;">"${subject}"</span></div>

                            <label class="small fw-bold text-muted mb-1" style="font-size:11px;">Kata Laluan</label>
                            <input type="password" class="form-control form-control-sm mb-3" placeholder="Masukkan kata laluan" readonly value="••••••••">
                            <button class="btn btn-warning btn-sm w-100 fw-bold">${link}</button>
                        </div>
                        <div class="text-center mt-3">
                            <button class="btn btn-sm btn-outline-secondary rounded-pill" onclick="resetPreviewStep()"><ion-icon name="refresh-outline" class="align-middle me-1"></ion-icon> Kembali ke Emel</button>
                        </div>`;
                    }
                }
                else if (type === "Social") {
                    var senderLower = sender.toLowerCase();
                    var iconName = senderLower.includes("facebook") || senderLower.includes("fb") ? "logo-facebook" :
                                   senderLower.includes("instagram") || senderLower.includes("ig") ? "logo-instagram" : "notifications";
                    var iconColor = senderLower.includes("facebook") || senderLower.includes("fb") ? "#1877F2" :
                                    senderLower.includes("instagram") || senderLower.includes("ig") ? "#E1306C" : "#1a1a1a";

                    desktopContent = `
                    <div class="mx-auto" style="max-width: 320px;">
                        <div class="notification-screen" style="border-radius: 20px; overflow: hidden; height: 400px; position: relative;">
                            <div class="lock-clock">
                                <h1 class="fw-bold mb-0">12:45</h1><p class="small">Khamis, 12 Jun</p>
                            </div>
                            <div class="social-notif">
                                <div class="notif-icon" style="color: ${iconColor};"><ion-icon name="${iconName}"></ion-icon></div>
                                <div class="notif-content text-start">
                                    <div class="notif-header"><span class="notif-title">${sender}</span><span class="notif-time">Baru saja</span></div>
                                    <div class="notif-body"><strong>${subject}</strong><br>${body}<div class="mt-2 text-center"><span class="text-primary fw-bold text-decoration-underline" style="font-size:11px;">${link}</span></div></div>
                                </div>
                            </div>
                        </div>
                    </div>`;
                }
                else if (type === "Antivirus") {
                    desktopContent = `<div class="av-body rounded-4 shadow-sm py-5"><ion-icon name="shield-alert-outline" class="av-icon mb-2" style="font-size: 3rem;"></ion-icon><h5 class="fw-bold text-white mb-1">${sender}</h5><h6 class="text-warning fw-bold mb-2" style="font-size: 12px;">Subjek: ${subject}</h6><p class="small mb-3 text-white-50" style="font-size: 11px;">${body}</p><button class="btn btn-danger btn-sm w-100 fw-bold py-2"><ion-icon name="sync-outline" class="me-1"></ion-icon>${link}</button></div>`;
                }
                else {
                    desktopContent = `<div class="bg-white p-4 rounded-3 shadow-sm border text-start"><div class="d-flex align-items-center mb-3 border-bottom pb-3"><div class="bg-danger rounded-circle text-white d-flex justify-content-center align-items-center me-3 fw-bold" style="width:35px; height:35px; font-size:14px;">!</div><div style="line-height:1.2"><div class="fw-bold text-dark" style="font-size:14px;">${sender}</div><small class="text-muted" style="font-size:11px;">Subjek: ${subject}</small></div></div><p class="small mb-4" style="font-size:12px;">${body}</p><div class="bg-light p-3 rounded border text-center small text-primary text-decoration-underline fw-bold" style="font-size: 12px;">${link}</div></div>`;
                }

                html = `<div class="fake-browser shadow-sm w-100"><div class="p-3" style="background: #f8fafc; min-height: 350px;">${desktopContent}</div></div>`;
            }

            if (container) {
                container.innerHTML = html;
            }
        }
    </script>
}