@model IEnumerable<KenalPhishing.Models.Module>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Pengurusan Modul";
}

@section Styles {
    <link href="~/Content/Admin.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/Dashboard.css" rel="stylesheet" type="text/css" />
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Senarai Modul</h2>
        <a href="@Url.Action("EditModule", "Admin")" class="btn btn-dark rounded-pill px-4">
            <ion-icon name="add-outline" class="me-2 align-middle"></ion-icon> Tambah Modul
        </a>
    </div>

    <!-- Bahagian Penapisan -->
    <div class="card border-0 shadow-sm rounded-4 p-3 mb-4">
        <div class="row align-items-center">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-0"><ion-icon name="filter-outline"></ion-icon></span>
                    <select id="categoryFilter" class="form-select border-0 bg-light rounded-3">
                        <option value="all">Semua Kategori</option>
                        <option value="Adult">Dewasa (Adult)</option>
                        <option value="Child">Kanak-Kanak (Child)</option>
                        <option value="Elder">Warga Emas (Elder)</option>
                    </select>
                </div>
            </div>
            <div class="col-md-8 text-md-end mt-2 mt-md-0">
                <small class="text-muted italic">* Gunakan menu di atas untuk menapis senarai dengan pantas.</small>
            </div>
        </div>
    </div>

    <div class="admin-table-card shadow-sm overflow-hidden bg-white rounded-4 border">
        <table class="table table-hover mb-0" id="moduleTable">
            <thead class="bg-dark text-white">
                <tr>
                    <th class="ps-4" style="width: 50px;">#</th>
                    <th>Kod</th>
                    <th>Tajuk Modul</th>
                    <th>Kategori</th>
                    <th>Ikon</th>
                    <th class="text-center pe-4">Tindakan</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center p-4 text-muted">Tiada modul direkodkan. Sila tambah modul baharu.</td>
                    </tr>
                }
                else
                {
                    int i = 1;
                    foreach (var mod in Model)
                    {
                        @* Tambah data-category di sini *@
                        <tr class="module-row" data-category="@mod.Category">
                            <td class="ps-4 text-muted numbering">@(i++)</td>
                            <td class="fw-bold text-muted">@mod.ModuleCode</td>
                            <td class="fw-bold">@mod.Title</td>
                            <td class="category-cell">
                                @if (mod.Category == "Elder")
                                {<span class="badge bg-warning text-dark">Warga Emas</span> }
                                else if (mod.Category == "Adult")
                                { <span class="badge bg-primary">Dewasa</span> }
                                else
                                { <span class="badge bg-success">Kanak-Kanak</span>}
                            </td>
                            <td><ion-icon name="@mod.Icon" class="fs-5"></ion-icon></td>
                            <td class="text-center pe-4">
                                <a href="@Url.Action("EditModule", "Admin", new { id = mod.Id })" class="btn btn-sm btn-outline-dark me-2">Sunting</a>
                                <form action="@Url.Action("DeleteModule", "Admin")" method="post" class="d-inline" onsubmit="return confirm('Anda pasti mahu memadam modul ini?');">
                                    <input type="hidden" name="id" value="@mod.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">Hapus</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const filterDropdown = document.getElementById('categoryFilter');
            const moduleRows = document.querySelectorAll('.module-row');

            if (filterDropdown instanceof HTMLSelectElement) {
                filterDropdown.addEventListener('change', function () {
                    const selectedCategory = filterDropdown.value;

                    moduleRows.forEach(function (row) {
                        if (row instanceof HTMLElement) {
                            const rowCategory = row.getAttribute('data-category');

                            if (selectedCategory === "all" || rowCategory === selectedCategory) {
                                row.style.display = "";
                            } else {
                                row.style.display = "none";
                            }
                        }
                    });
                });
            }
        });
    </script>
}