@model KenalPhishing.Models.SystemSetting
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Konfigurasi Sistem";
}

@section Styles {
    <link href="~/Content/Admin.css" rel="stylesheet" type="text/css" />
    <style>
        .config-card {
            transition: all 0.3s ease;
            border: 1px solid rgba(0,0,0,0.05);
        }

            .config-card:hover {
                box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
            }

        .form-switch .form-check-input {
            width: 3em;
            height: 1.5em;
            cursor: pointer;
        }

        .section-icon {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
        }

        .extra-small {
            font-size: 11px;
        }
    </style>
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-1">Konfigurasi Sistem</h2>
            <p class="text-muted mb-0">Urus tetapan global dan parameter keselamatan platform KenalPhishing.</p>
        </div>
        <div class="text-end">
            <span class="badge bg-dark rounded-pill px-3 py-2">Versi Sistem: v2.4.0-stable</span>
        </div>
    </div>

    @using (Html.BeginForm("UpdateSystemSettings", "Admin", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)

        <div class="row g-4">
            <!-- LEFT: Platform Operations -->
            <div class="col-lg-6">
                <div class="card p-4 rounded-4 border-0 shadow-sm config-card h-100">
                    <div class="d-flex align-items-center mb-4">
                        <div class="section-icon bg-primary bg-opacity-10 text-primary me-3">
                            <ion-icon name="options-outline" class="fs-4"></ion-icon>
                        </div>
                        <h6 class="fw-bold m-0">Operasi Platform</h6>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-light rounded-3">
                        <div>
                            <p class="mb-0 fw-bold">Mod Penyelenggaraan (Maintenance)</p>
                            <span class="extra-small text-muted">Halang akses pelajar semasa kemas kini sistem.</span>
                        </div>
                        <div class="form-check form-switch">
                            @* Checkbox logic *@
                            <input class="form-check-input" type="checkbox" name="IsMaintenanceMode" value="true" role="switch" @(Model.IsMaintenanceMode ? "checked" : "")>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="small fw-bold text-muted mb-2">Pengumuman Global Dashboard</label>
                        @Html.TextAreaFor(m => m.GlobalAnnouncement, new { @class = "form-control bg-light border-0 p-3 small", rows = "3", placeholder = "Masukkan mesej pengumuman..." })
                        <div class="form-text extra-small mt-2">Mesej ini akan muncul pada bar notifikasi semua pengguna.</div>
                    </div>
                </div>
            </div>

            <!-- RIGHT: Awareness Score Parameters -->
            <div class="col-lg-6">
                <div class="card p-4 rounded-4 border-0 shadow-sm config-card h-100">
                    <div class="d-flex align-items-center mb-4">
                        <div class="section-icon bg-success bg-opacity-10 text-success me-3">
                            <ion-icon name="analytics-outline" class="fs-4"></ion-icon>
                        </div>
                        <h6 class="fw-bold m-0">Parameter Skor Kesedaran</h6>
                    </div>

                    <p class="text-muted small mb-4">Tentukan skor minimum (peratus) untuk lulus modul bagi setiap kategori.</p>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="extra-small fw-bold text-uppercase ls-1">Kanak-kanak</label>
                            <div class="input-group mt-1">
                                @Html.TextBoxFor(m => m.ScoreChild, new { @type = "number", @class = "form-control bg-light border-0 p-3" })
                                <span class="input-group-text bg-light border-0">%</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="extra-small fw-bold text-uppercase ls-1">Dewasa</label>
                            <div class="input-group mt-1">
                                @Html.TextBoxFor(m => m.ScoreAdult, new { @type = "number", @class = "form-control bg-light border-0 p-3" })
                                <span class="input-group-text bg-light border-0">%</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="extra-small fw-bold text-uppercase ls-1">Warga Emas</label>
                            <div class="input-group mt-1">
                                @Html.TextBoxFor(m => m.ScoreElder, new { @type = "number", @class = "form-control bg-light border-0 p-3" })
                                <span class="input-group-text bg-light border-0">%</span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 p-3 border rounded-3 bg-light bg-opacity-50">
                        <div class="d-flex gap-2 align-items-start">
                            <ion-icon name="information-circle-outline" class="text-primary fs-5"></ion-icon>
                            <p class="extra-small text-muted mb-0">Skor ini menentukan kelayakan penjanaan <b>Sijil Digital</b> secara automatik selepas kuiz tamat.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- BOTTOM: Security & System Limits -->
            <div class="col-12">
                <div class="card p-4 rounded-4 border-0 shadow-sm border-start border-5 border-warning config-card">
                    <div class="d-flex align-items-center mb-4">
                        <div class="section-icon bg-warning bg-opacity-10 text-warning me-3">
                            <ion-icon name="shield-checkmark-outline" class="fs-4"></ion-icon>
                        </div>
                        <h6 class="fw-bold m-0">Kawalan Keselamatan & Had Sistem</h6>
                    </div>

                    <div class="row g-4 align-items-end">
                        <div class="col-md-4">
                            <label class="small fw-bold text-muted mb-2">Had Percubaan Kuiz</label>
                            <select name="QuizAttempts" class="form-select border-0 bg-light p-3">
                                <option value="3" @(Model.QuizAttempts == 3 ? "selected" : "")>3 Percubaan</option>
                                <option value="5" @(Model.QuizAttempts == 5 ? "selected" : "")>5 Percubaan</option>
                                <option value="0" @(Model.QuizAttempts == 0 ? "selected" : "")>Tanpa Had (Latihan)</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="small fw-bold text-muted mb-2">Sesi Log Keluar Automatik (Idle)</label>
                            <select name="SessionTimeout" class="form-select border-0 bg-light p-3">
                                <option value="30" @(Model.SessionTimeout == 30 ? "selected" : "")>30 Minit</option>
                                <option value="60" @(Model.SessionTimeout == 60 ? "selected" : "")>1 Jam</option>
                                <option value="0" @(Model.SessionTimeout == 0 ? "selected" : "")>Tutup (Sentiasa Aktif)</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-warning rounded-pill w-100 py-3 fw-bold shadow-sm">
                                <ion-icon name="cloud-upload-outline" class="me-2 align-middle"></ion-icon> Kemaskini Protokol
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Audit Hint -->
    <div class="mt-5 text-center">
        <p class="extra-small text-muted">
            <ion-icon name="time-outline" class="align-middle"></ion-icon>
            Kemas kini terakhir oleh <b>@(Model.UpdatedBy ?? "System")</b> pada @(Model.LastUpdated.HasValue ? Model.LastUpdated.Value.ToString("dd MMM yyyy, hh:mm tt") : "Tiada Data")
        </p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
        <div class="toast show align-items-center text-white bg-success border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    @TempData["SuccessMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}