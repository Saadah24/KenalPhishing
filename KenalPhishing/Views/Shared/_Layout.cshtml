<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - KenalPhishing</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom Site CSS -->
    <link href="~/Content/Site.css?v=1.3" rel="stylesheet" type="text/css" />

    @RenderSection("Styles", required: false)

    <!-- IonIcons Library -->
    <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>
</head>
<body class="main-body">

    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-light nav-custom sticky-top bg-white shadow-sm">
        <div class="container py-2">
            <a class="navbar-brand brand-bold text-dark d-flex align-items-center gap-2 text-decoration-none" href="@Url.Action("Index", "Home")">
                <ion-icon name="shield-checkmark-outline" class="text-primary fs-4"></ion-icon>
                <span>KenalPhishing</span>
            </a>

            <!-- BUTANG MENU (HAMBURGER) -->
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- ISI MENU -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                    <li class="nav-item"><a class="nav-link fw-semibold text-secondary" href="@Url.Action("Index", "Home")">Utama</a></li>
                    <li class="nav-item"><a class="nav-link fw-semibold text-secondary" href="@Url.Action("Index", "Home")#modul">Modul</a></li>
                </ul>
                <div class="nav-auth-buttons d-flex flex-column flex-lg-row align-items-lg-center gap-3 mt-3 mt-lg-0">
                    <a href="@Url.Action("Login", "Account")" class="login-link text-secondary fw-semibold text-decoration-none">Log Masuk</a>
                    <a href="@Url.Action("Register", "Account")" class="btn btn-primary register-btn px-4 py-2">Daftar Masuk</a>
                </div>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <!-- Footer (Sama seperti asal anda) -->
    <footer class="footer-section mt-5 bg-dark text-white">
        <div class="container py-5">
            <!-- Isi footer anda di sini... -->
            <p class="small mb-0 text-center text-white-50">© @DateTime.Now.Year KenalPhishing | Hak Cipta Terpelihara</p>
        </div>
    </footer>

    <!-- JAVASCRIPT - INI ADALAH KUNCI UNTUK MENU BERFUNGSI -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>