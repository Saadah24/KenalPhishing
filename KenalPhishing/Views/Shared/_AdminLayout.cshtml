<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Admin KenalPhishing</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/Admin.css" rel="stylesheet" type="text/css" />

    <style>
        /* Ensures the highlighted page always has a consistent blue background */
        .admin-sidebar .nav-link.active {
            background-color: #0d6efd !important;
            color: white !important;
        }

        /* Updates logout button to a consistent red color */
        .btn-logout {
            background-color: #dc3545 !important;
            color: white !important;
            border: none;
        }

            .btn-logout:hover {
                background-color: #bb2d3b !important;
                color: white !important;
            }
    </style>

    @RenderSection("Styles", required: false)

</head>
<body class="dashboard-body">
    <div class="d-flex">
        <!-- Sidebar Admin -->
        <nav class="sidebar admin-sidebar shadow-lg">
            <div class="sidebar-header p-4">
                <h4 class="fw-bold mb-0">KenalPhishing</h4>
                <span class="admin-badge fw-bold uppercase">ADMIN PANEL</span>
            </div>
            <ul class="nav flex-column px-3 mt-4">
                <li class="nav-item mb-2">
                    <a href="@Url.Action("Index", "Admin")" class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Index" ? "active" : "")">
                        <ion-icon name="stats-chart-outline"></ion-icon> <span>Ringkasan Admin</span>
                    </a>
                </li>
                <li class="nav-item mb-2">
                    <a href="@Url.Action("ManageModules", "Admin")" class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "ManageModules" ? "active" : "")">
                        <ion-icon name="layers-outline"></ion-icon> <span>Urus Modul</span>
                    </a>
                </li>
                <li class="nav-item mb-2">
                    <a href="@Url.Action("ManageUsers", "Admin")" class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "ManageUsers" ? "active" : "")">
                        <ion-icon name="people-outline"></ion-icon> <span>Senarai Pelajar</span>
                    </a>
                </li>
                <li class="nav-item mb-2">
                    <a href="@Url.Action("ManageAlerts", "Admin")" class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "ManageAlerts" ? "active" : "")">
                        <ion-icon name="shield-half-outline"></ion-icon> <span>Urus Amaran</span>
                    </a>
                </li>
                <li class="nav-item mb-2">
                    <a href="@Url.Action("ManageReports", "Admin")" class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "ManageReports" ? "active" : "")">
                        <ion-icon name="megaphone-outline"></ion-icon> <span>Laporan Scam</span>
                    </a>
                </li>
                <li class="nav-item mb-2">
                    <!-- FIXED LOGIC: Changed from ViewBag.Title to RouteData for consistency -->
                    <a href="@Url.Action("SystemConfig", "Admin")" class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "SystemConfig" ? "active" : "")">
                        <ion-icon name="settings-outline"></ion-icon>
                        <span>Konfigurasi Sistem</span>
                    </a>
                </li>
            </ul>
            <div class="sidebar-footer p-4 mt-auto">
                <!-- Log keluar kembali ke Landing Page -->
                <a href="@Url.Action("Index", "Home")" class="btn btn-logout w-100">
                    <ion-icon name="log-out-outline"></ion-icon> Log Keluar Admin
                </a>
            </div>
        </nav>

        <!-- Main Content Area -->
        <div class="content-wrapper flex-grow-1">
            <header class="dashboard-header d-flex justify-content-between align-items-center p-4 bg-white border-bottom">
                <div class="search-box">
                    <ion-icon name="search-outline"></ion-icon>
                    <input type="text" placeholder="Cari data...">
                </div>

                <div class="user-profile-nav d-flex align-items-center">
                    <div class="text-end me-3">
                        <p class="fw-bold mb-0 small">@Session["UserName"]</p>
                        <p class="extra-small text-muted mb-0">Administrator</p>
                    </div>
                    <div class="avatar-sm bg-dark text-white d-flex align-items-center justify-content-center rounded-circle">
                        <ion-icon name="person-circle" class="fs-2"></ion-icon>
                    </div>
                </div>
            </header>

            <div class="p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>