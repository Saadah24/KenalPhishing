@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    string selected = ViewBag.SelectedCategory;
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-white">Teroka Modul: @selected</h2>
        <p class="text-muted">Daftar akaun untuk mula belajar secara interaktif.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <!-- Preview Modul (Gated) -->
            <div class="card bg-dark border-secondary p-4 mb-4">
                <div class="d-flex align-items-center gap-4">
                    <div class="preview-thumb bg-secondary rounded-3" style="width:100px; height:100px;"></div>
                    <div class="flex-grow-1">
                        <h4 class="text-white fw-bold">Pengenalan Asas Phishing</h4>
                        <p class="text-muted small">Ketahui cara mengenal pasti emel dan SMS palsu dalam 10 minit.</p>
                    </div>
                    <!-- Butang ini mengunci akses -->
                    <a href="@Url.Action("Login", "Account")" class="btn btn-warning rounded-pill px-4 fw-bold">
                        <ion-icon name="lock-closed-outline" class="me-2"></ion-icon> Daftar Untuk Akses
                    </a>
                </div>
            </div>

            <!-- Pesanan Galakan -->
            <div class="alert alert-info bg-dark text-info border-info mt-5 p-4 rounded-4 text-center">
                <h5 class="fw-bold">Ingin akses lebih banyak?</h5>
                <p>Log masuk atau daftar sekarang untuk akses kepada Simulasi, Kuiz, dan Sijil Pencapaian.</p>
                <div class="mt-3">
                    <a href="@Url.Action("Register", "Account")" class="btn btn-outline-info rounded-pill px-4">Daftar Sekarang</a>
                </div>
            </div>
        </div>
    </div>
</div>