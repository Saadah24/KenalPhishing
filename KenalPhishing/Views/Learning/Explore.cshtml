@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    string selected = ViewBag.SelectedCategory ?? "Adult";

    // Setup dynamic variables that perfectly map to your CSS definitions
    string themeClass = "theme-adult";
    string categoryTitle = "Dewasa (18 - 59 Tahun)";
    string categoryDesc = "Slaid interaktif, simulasi phishing emel tempat kerja yang realistik, dan amalan terbaik keselamatan siber untuk melindungi aset peribadi dan korporat.";
    string iconName = "laptop-outline";
    string lessonShortDesc = "Ketahui cara mengenal pasti emel dan SMS palsu dalam 10 minit. Mengandungi panduan visual mengecam domain mencurigakan serta manipulasi psikologi biasa.";

    if (selected == "Child" || selected.Equals("Child", StringComparison.OrdinalIgnoreCase))
    {
        themeClass = "theme-child";
        categoryTitle = "Pelajar Sekolah (7 - 17 Tahun)";
        categoryDesc = "Kandungan interaktif dengan gaya penceritaan santai, grafik ringkas, dan visual menarik untuk mendidik keselamatan asas atas talian.";
        iconName = "happy-outline";
        lessonShortDesc = "Kuasai kemahiran asas mengenali kiriman emel dan mesej palsu menerusi kuiz berasaskan visual mesra kanak-kanak dalam masa 10 minit.";
    }
    else if (selected == "Elder" || selected.Equals("Elder", StringComparison.OrdinalIgnoreCase))
    {
        themeClass = "theme-elder";
        categoryTitle = "Warga Emas (60+ Tahun)";
        categoryDesc = "Kandungan dengan teks bersaiz besar, penerangan ringkas tanpa terma teknikal yang rumit, serta tumpuan khas kepada taktik penipuan panggilan & SMS wang persaraan.";
        iconName = "accessibility-outline";
        lessonShortDesc = "Penerangan langkah demi langkah yang mudah difahami bagi mengenal pasti mesej layangan dan taktik ugutan pemindahan akaun bank dalam tempoh 10 minit.";
    }
}

<div class="container py-5 @themeClass">
    <!-- Clean, glare-free layout page container that adapts perfectly to your custom property structures -->
    <div class="explore-wrapper p-4 p-md-5 rounded-4 shadow-sm border" style="background-color: var(--bg-soft); color: var(--text-color); border-color: rgba(0,0,0,0.06) !important; transition: all 0.3s ease;">
        <div class="text-center mb-5">
            <div class="category-badge mb-3 d-inline-flex align-items-center gap-2 px-3 py-1.5 rounded-pill" style="background-color: rgba(0,0,0,0.04); color: var(--primary-color); border: 1.5px solid var(--primary-color);">
                <ion-icon name="@iconName" style="color: var(--primary-color); font-size: 1.25rem; pointer-events: none;"></ion-icon>
                <span class="fw-semibold text-uppercase" style="font-size: 0.8rem; letter-spacing: 1px;">Kategori: @selected</span>
            </div>
            <h2 class="fw-bold mb-3" style="color: var(--text-color);">Teroka Modul: @categoryTitle</h2>
            <div class="row justify-content-center">
                <div class="col-md-10">
                    <p class="fs-5 leading-relaxed opacity-75">@categoryDesc</p>
                </div>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-10">
                <!-- Preview Modul (Gated) -->
                <div class="card border-0 p-4 mb-4 shadow-sm" style="background-color: var(--sidebar-bg); border-radius: 1.5rem; border: 1px solid rgba(0,0,0,0.04) !important;">
                    <div class="d-flex align-items-center gap-4 flex-column flex-md-row text-center text-md-start">
                        <div class="preview-thumb rounded-3 d-flex align-items-center justify-content-center" style="width:100px; height:100px; background-color: var(--bg-soft); border: 1.5px solid var(--primary-color); flex-shrink:0;">
                            <ion-icon name="book-outline" style="font-size: 2.5rem; color: var(--primary-color); pointer-events: none;"></ion-icon>
                        </div>
                        <div class="flex-grow-1">
                            <span class="badge mb-2 px-3 py-1.5 rounded-pill" style="background-color: var(--primary-color); color: #ffffff; font-size: 0.75rem;">Modul Asas</span>
                            <h4 class="fw-bold mb-2" style="color: var(--text-color);">Pengenalan Asas Phishing</h4>
                            <p class="small mb-0 opacity-75" style="color: var(--text-color);">
                                @lessonShortDesc
                            </p>
                        </div>
                        <!-- Lock Access Button -->
                        <a href="@Url.Action("Login", "Account")" class="btn rounded-pill px-4 py-2.5 fw-bold flex-shrink-0 text-white text-decoration-none" style="background-color: var(--primary-color); border: none; font-size: 0.9rem; transition: transform 0.2s ease;">
                            <ion-icon name="lock-closed-outline" class="me-2" style="color: #ffffff; pointer-events: none;"></ion-icon> Daftar Untuk Akses
                        </a>
                    </div>
                </div>

                <!-- Encouragement card -->
                <div class="alert mt-5 p-4 rounded-4 text-center border-0 shadow-sm" style="background-color: var(--sidebar-bg); color: var(--text-color); border: 1px solid rgba(0,0,0,0.04) !important;">
                    <h5 class="fw-bold mb-2">Ingin akses lebih banyak kandungan pembelajaran?</h5>
                    <p class="mb-3 opacity-75">Log masuk atau daftar sekarang untuk akses penuh kepada Simulasi, Kuiz Interaktif, dan Sijil Pencapaian Digital.</p>
                    <div>
                        <a href="@Url.Action("Register", "Account")" class="btn rounded-pill px-5 py-2.5 fw-bold text-white text-decoration-none" style="background-color: var(--primary-color); border: none; transition: transform 0.2s ease;">Daftar Sekarang</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>