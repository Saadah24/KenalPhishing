@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Kuiz Salah";
}

@section Styles {
    <link href="~/Content/Quiz.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/Dashboard.css" rel="stylesheet" type="text/css" />
}

<div class="result-container py-5 text-center">
    <div class="result-card p-5 shadow-lg">
        <div class="mb-4">
            <ion-icon name="close-circle" class="display-1 text-danger"></ion-icon>
        </div>
        <h2 class="fw-bold mb-4"><span class="text-danger">MAAF, JAWAPAN ANDA SALAH</span></h2>

        <div class="row g-4 mb-5 text-start">
            <div class="col-md-6 mx-auto">
                <div class="tips-summary-card p-4 shadow-sm border-start border-5 border-danger">
                    <h6 class="fw-bold mb-3 border-bottom pb-2">Kenapa Salah?</h6>
                    <p class="small">Scammer kini sangat bijak meniru nama dan alamat emel (A & B). Tanda paling jelas adalah <b>tekanan masa</b> yang mereka berikan kepada anda.</p>
                </div>
            </div>
        </div>

        <div class="result-actions d-flex justify-content-center gap-3">
            <a href="@Url.Action("Quiz", "Dashboard")" class="btn btn-outline-dark rounded-pill px-4">Cuba Lagi</a>
            <a href="@Url.Action("Study", "Dashboard")" class="btn btn-dark rounded-pill px-4">Baca Modul Semula</a>
        </div>
    </div>
</div>