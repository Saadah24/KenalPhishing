@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Bilik Simulasi Interaktif";
    string category = Session["UserCategory"]?.ToString() ?? "Adult";
}

@section Styles {
    <link href="@Url.Content("~/Content/Simulation.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/Dashboard.css")" rel="stylesheet" type="text/css" />
}

<div class="container-fluid py-4">
    <div class="row g-4">
        <!-- BAHAGIAN KIRI: KAWASAN SIMULASI -->
        <div class="col-lg-8">
            <div class="fake-browser shadow-lg">
                <!-- Bar Alamat (Akan berubah bila masuk stage 2) -->
                <div class="browser-top">
                    <div class="d-flex gap-1">
                        <span style="width:10px;height:10px;background:#ff5f56;border-radius:50%"></span>
                        <span style="width:10px;height:10px;background:#ffbd2e;border-radius:50%"></span>
                        <span style="width:10px;height:10px;background:#27c93f;border-radius:50%"></span>
                    </div>
                    <div class="url-bar" id="currentUrl">
                        @if (category == "Child")
                        {<span>Mesej Dari: GameMaster</span> }
                        else if (category == "Elder")
                        { <span>Mesej SMS (63001)</span> }
                        else
                        { <span>https://mail.google.com/inbox</span>}
                    </div>
                </div>

                <!-- STAGE 1: TERIMA MESEJ (PANDANGAN AWAL) -->
                <div id="stage1" class="p-5 text-dark">
                    @if (category == "Child")
                    {
                        <div class="alert alert-primary border-0 p-4 rounded-4">
                            <h4 class="fw-bold"><ion-icon name="gift-outline" class="me-2"></ion-icon>Hadiah Percuma!</h4>
                            <p>Anda terpilih memenangi <b>10,000 Robux</b> secara percuma hari ini sahaja!</p>
                            <button class="btn btn-primary rounded-pill px-4 mt-3" onclick="goToFakePage()">TEBUS SEKARANG</button>
                        </div>
                    }
                    else if (category == "Elder")
                    {
                        <div style="background:#e5e5ea; padding:20px; border-radius:15px; max-width:300px; margin:0 auto;">
                            <p class="small mb-2">
                                <b>[RM0.00]</b> Bank: Akaun anda telah disekat. Sila sahkan akaun anda melalui pautan ini untuk aktifkan semula: <br>
                                <a href="javascript:void(0)" class="text-primary" onclick="goToFakePage()">http://bit.ly/sah-akaun-bank</a>
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="email-mockup border p-4 bg-light rounded-3">
                            <h6 class="fw-bold border-bottom pb-2">Keselamatan Maybank2u</h6>
                            <p class="small mt-3">Kami mengesan cubaan log masuk tidak sah. Sila klik butang di bawah untuk mengesahkan identiti anda.</p>
                            <button class="btn btn-warning btn-sm mt-2 px-4 fw-bold" onclick="goToFakePage()">Sahakan Identiti</button>
                        </div>
                    }
                </div>

                <!-- STAGE 2: LAMAN LOGIN PALSU (MUNCUL SELEPAS KLIK) -->
                <div id="stage2" class="hidden-stage p-4 text-dark bg-light" style="min-height:450px;">
                    <div class="fake-login-card border">
                        @if (category == "Child")
                        {
                            <h3 class="text-center fw-bold text-primary mb-4">Game Login</h3>
                            <input type="text" class="form-control mb-2" placeholder="Nama Wira (Username)">
                            <input type="password" class="form-control mb-3" placeholder="Kata Laluan Rahsia">
                            <button class="btn-fake-login child-theme-btn" onclick="checkFakeLogin()">LOG MASUK UNTUK HADIAH</button>
                        }
                        else
                        {
                            <h3 class="text-center fw-bold mb-4">Maybank<span class="text-warning">2u</span></h3>
                            <input type="text" class="form-control mb-2" placeholder="Username">
                            <input type="password" class="form-control mb-3" placeholder="Password">
                            <button class="btn-fake-login @(category == "Elder" ? "elder-theme-btn" : "adult-theme-btn")" onclick="checkFakeLogin()">LOGIN</button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- KANAN: PANEL TINDAKAN -->
        <div class="col-lg-4">
            <div class="card p-4 rounded-4 shadow-sm border-0 bg-light-grey text-dark h-100">
                <h5 class="fw-bold mb-4">Analisis Risiko</h5>
                <p class="small mb-5">Jika anda rasa halaman di sebelah adalah palsu, sila lapor dengan segera.</p>

                <div class="d-grid gap-3">
                    <button class="btn btn-danger rounded-pill py-3 fw-bold shadow" onclick="finalDecision('phishing')">LAPOR (INI SCAM!)</button>
                    <button class="btn btn-dark rounded-pill py-3 fw-bold" onclick="finalDecision('safe')">SAHKAN SELAMAT</button>
                </div>

                <div class="mt-auto pt-4 border-top">
                    <div class="d-flex justify-content-between">
                        <span class="small fw-bold">Nyawa:</span>
                        <span class="text-danger">🧡🧡🧡</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- FEEDBACK MODAL (DENGAN NAVIGASI SELEPAS SIMULASI) -->
<div class="modal fade" id="eduModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 overflow-hidden shadow-lg">
            <div id="mHeader" class="p-4 text-center text-white">
                <ion-icon id="mIcon" name="" style="font-size: 5rem;"></ion-icon>
                <h3 id="mTitle" class="fw-bold mt-2"></h3>
            </div>
            <div class="modal-body p-4 bg-white text-dark text-center">
                <!-- Teks penjelasan -->
                <div id="mText" class="mb-4 small p-3 bg-light rounded-3 border text-start"></div>

                <h6 class="fw-bold mb-3 small">Apa tindakan anda seterusnya?</h6>

                <!-- BUTANG NAVIGASI (DIRECTIONARY) -->
                <div class="d-grid gap-2">
                    <a href="@Url.Action("Quiz", "Dashboard")" class="btn btn-primary rounded-pill fw-bold">
                        <ion-icon name="help-circle-outline" class="me-2"></ion-icon> Mula Kuiz Sekarang
                    </a>

                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-dark flex-grow-1 rounded-pill" onclick="resetSimulation()">
                            <ion-icon name="refresh-outline" class="me-1"></ion-icon> Ulang Lagi
                        </button>
                        <a href="@Url.Action("Index", "Dashboard")" class="btn btn-dark flex-grow-1 rounded-pill">
                            <ion-icon name="home-outline" class="me-1"></ion-icon> Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var myModal = new bootstrap.Modal(document.getElementById('eduModal'));

        // FUNGSI 1: Tukar paparan mesej ke laman web palsu
        function goToFakePage() {
            document.getElementById('stage1').classList.add('hidden-stage');
            document.getElementById('stage2').classList.remove('hidden-stage');

            // Tukar URL Bar supaya nampak mencurigakan
            var urlText = "@category" === "Child" ? "robux-free-generator.net/verify" : "www.maybank2u-secure.net/login";
            document.getElementById('currentUrl').innerHTML = '<ion-icon name="lock-open-outline" class="text-danger me-2"></ion-icon>' + urlText;
        }

        // FUNGSI 2: Jika user teruskan juga isi data di page palsu
        function checkFakeLogin() {
            var h = document.getElementById('mHeader');
            var i = document.getElementById('mIcon');
            var t = document.getElementById('mTitle');
            var txt = document.getElementById('mText');

            h.className = "p-4 text-center text-white bg-warning";
            i.setAttribute("name", "alert-triangle");
            t.innerText = "Bahaya Dikesan!";
            txt.innerHTML = "<b>Kenapa anda cuba Login?</b><br>Perhatikan URL di bar alamat. Ia menggunakan <b>.net</b> bukannya <b>.com.my</b>. Jika anda masukkan password di sini, maklumat anda akan terus dihantar ke database scammer!";
            myModal.show();
        }

        // FUNGSI 3: Keputusan akhir (Lapor)
        function finalDecision(type) {
            var h = document.getElementById('mHeader');
            var i = document.getElementById('mIcon');
            var t = document.getElementById('mTitle');
            var txt = document.getElementById('mText');

            if(type === 'phishing') {
                h.className = "p-4 text-center text-white bg-success";
                i.setAttribute("name", "checkmark-circle");
                t.innerText = "Keputusan Tepat!";
                txt.innerHTML = "Tahniah! Anda berjaya mengesan taktik pancingan data ini. Anda selamat!";
            } else {
                h.className = "p-4 text-center text-white bg-danger";
                i.setAttribute("name", "close-circle");
                t.innerText = "Anda Terjerat!";
                txt.innerHTML = "Laman web ini adalah 100% palsu. Dengan mengesahkan ia 'Selamat', anda telah membiarkan maklumat peribadi anda dicuri.";
            }
            myModal.show();
        }
    </script>


    <script>
    // ... kod JS sedia ada ...

    function resetSimulation() {
        // 1. Tutup modal
        myModal.hide();

        // 2. Paparkan semula Stage 1 (Mesej/Emel/SMS)
        document.getElementById('stage1').classList.remove('hidden-stage');

        // 3. Sembunyikan Stage 2 (Login Page)
        document.getElementById('stage2').classList.add('hidden-stage');

        // 4. Tukar balik URL Bar ke asal
        var originalUrl = "@category" === "Child" ? "Mesej Dari: GameMaster" :
                          "@category" === "Elder" ? "Mesej SMS (63001)" :
                          "https://mail.google.com/inbox";
        document.getElementById('currentUrl').innerText = originalUrl;
    }

    // Pastikan fungsi finalDecision memaparkan modal dengan butang baru
    function finalDecision(type) {
        var h = document.getElementById('mHeader');
        var i = document.getElementById('mIcon');
        var t = document.getElementById('mTitle');
        var txt = document.getElementById('mText');

        if(type === 'phishing') {
            h.className = "p-4 text-center text-white bg-success";
            i.setAttribute("name", "checkmark-circle");
            t.innerText = "Keputusan Tepat!";
            txt.innerHTML = "<b>Tahniah!</b> Anda berjaya mengesan taktik pancingan data ini. Anda kini bersedia untuk mengambil kuiz.";
        } else {
            h.className = "p-4 text-center text-white bg-danger";
            i.setAttribute("name", "close-circle");
            t.innerText = "Anda Terjerat!";
            txt.innerHTML = "<b>Opps!</b> Laman web ini palsu. Anda sepatutnya melaporkan halaman ini. Sila ulang simulasi untuk belajar lagi.";
        }
        myModal.show();
    }
    </script>
}