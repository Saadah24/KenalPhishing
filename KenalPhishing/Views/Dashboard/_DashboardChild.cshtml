@using KenalPhishing.Models
@{
    // 1. Ambil data daripada Controller
    int currentXP = ViewBag.CurrentXP ?? 0;
    int nextRankXP = ViewBag.NextRankXP ?? 1000;
    string levelName = ViewBag.LevelName ?? "Prajurit Muda";
    int badgeCount = ViewBag.Badges ?? 0;

    // Data untuk Mission Map (Modul)
    var allModules = ViewBag.ChildModules as List<Module> ?? new List<Module>();
    var completedIds = ViewBag.CompletedModuleIds as List<int> ?? new List<int>();
}

<style>
    /* Gamified Hover Effects */
    .mission-item {
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        border: 2px solid transparent !important;
    }

        .mission-item:hover {
            transform: scale(1.02);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
            border-color: #00b0ff !important;
            background-color: #ffffff !important;
        }

    .icon-box {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 18px;
        flex-shrink: 0;
    }

    .badge-locked {
        filter: grayscale(100%) blur(1px);
        opacity: 0.3;
    }

    .xp-progress-container {
        background: rgba(255, 255, 255, 0.2);
        height: 20px;
        border-radius: 50px;
        padding: 3px;
    }

    /* Animasi Bar XP Smooth */
    #xp-bar {
        width: 0%; /* Bermula dari 0 untuk animasi */
        transition: width 1.5s cubic-bezier(0.1, 0.5, 0.5, 1);
    }

    .pulse-icon {
        animation: pulse-animation 2s infinite;
    }

    @@keyframes pulse-animation {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.1);
        }

        100% {
            transform: scale(1);
        }
    }
</style>

<div class="row g-4">
    <!-- 1. HERO HEADER: MISSION CONTROL -->
    <div class="col-12">
        <div class="p-5 mb-2 shadow-lg text-white rounded-5 border-0"
             style="background: linear-gradient(135deg, #00b0ff 0%, #0072ff 100%); position: relative; overflow: hidden;">

            <ion-icon name="planet-outline" style="position: absolute; top: 10%; right: 5%; font-size: 10rem; opacity: 0.1; transform: rotate(-20deg);"></ion-icon>
            <ion-icon name="shield-outline" style="position: absolute; bottom: -20px; left: 10%; font-size: 8rem; opacity: 0.1;"></ion-icon>

            <div class="row align-items-center position-relative">
                <div class="col-md-2 text-center d-none d-md-block">
                    <ion-icon name="rocket" class="pulse-icon" style="font-size: 8rem; filter: drop-shadow(0 10px 15px rgba(0,0,0,0.3));"></ion-icon>
                </div>
                <div class="col-md-10">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <ion-icon name="ribbon" class="text-warning fs-3"></ion-icon>
                        <span class="fw-bold text-uppercase" style="letter-spacing: 2px; font-size: 14px;">Misi Aktif: Penjaga Siber</span>
                    </div>
                    <h1 class="fw-bold display-5">Hai, Wira @Session["UserName"]! 🛡️</h1>

                    <div class="mt-4" style="max-width: 600px;">
                        <div class="d-flex justify-content-between mb-2 small fw-bold text-white">
                            <span class="d-flex align-items-center gap-1">
                                <ion-icon name="trending-up" class="fs-5"></ion-icon> @levelName
                            </span>
                            <span class="d-flex align-items-center gap-1">
                                <ion-icon name="flash" class="text-warning fs-5"></ion-icon>
                                <span id="ali-xp-counter">0</span> / @nextRankXP XP
                            </span>
                        </div>

                        <!-- Bekas Bar -->
                        <div class="xp-progress-container border border-white border-opacity-50" style="background: rgba(255,255,255,0.2); height: 20px; border-radius: 50px; padding: 3px;">
                            <!-- Bar yang bergerak (Pastikan ID: ali-xp-bar) -->
                            <div id="ali-xp-bar"
                                 class="progress-bar bg-warning rounded-pill progress-bar-striped progress-bar-animated"
                                 style="width: 0%; height: 100%; transition: width 1.5s ease-in-out;">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. LEFT SIDEBAR: STATS & RANKING -->
    <div class="col-md-4">
        <!-- Lencana Section (BOLEH DIKLIK) -->
        <a href="@Url.Action("Lencana", "Dashboard")" class="text-decoration-none d-block mb-4">
            <div class="card p-4 rounded-5 border-0 shadow-sm text-center mission-item" style="background: #FFF9E6;">
                <div class="d-flex align-items-center justify-content-center gap-2 mb-3">
                    <ion-icon name="medal" class="text-warning fs-4"></ion-icon>
                    <h5 class="fw-bold text-warning m-0">Lencana Koleksi</h5>
                </div>

                <div class="d-flex justify-content-center gap-3 my-2">
                    <div title="Wira Pertama" class="icon-circle p-2 bg-white rounded-circle shadow-sm @(badgeCount < 1 ? "badge-locked" : "")">
                        <ion-icon name="ribbon" class="text-warning" style="font-size: 3rem;"></ion-icon>
                    </div>
                    <div title="Perisai Siber" class="icon-circle p-2 bg-white rounded-circle shadow-sm @(badgeCount < 2 ? "badge-locked" : "")">
                        <ion-icon name="shield-checkmark" class="text-primary" style="font-size: 3rem;"></ion-icon>
                    </div>
                    <div title="Terkunci" class="icon-circle p-2 bg-white rounded-circle shadow-sm @(badgeCount < 3 ? "badge-locked" : "")">
                        <ion-icon name="trophy" class="text-muted" style="font-size: 3rem;"></ion-icon>
                    </div>
                </div>

                <div class="mt-4 p-3 rounded-4 bg-white bg-opacity-50 border border-warning border-opacity-25">
                    <p class="small fw-bold mb-0 text-muted">
                        <ion-icon name="lock-open-outline" class="align-middle me-1"></ion-icon>
                        @(badgeCount >= 3 ? "Koleksi Hebat!" : "Selesaikan modul untuk lencana baru!")
                    </p>
                </div>
            </div>
        </a>

        <!-- Leaderboard (BOLEH DIKLIK) -->
        <a href="@Url.Action("Ranking", "Dashboard")" class="text-decoration-none d-block">
            <div class="card p-4 rounded-5 border-0 shadow-sm mission-item" style="background: #f8fbff;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h6 class="fw-bold m-0 d-flex align-items-center text-dark">
                        <ion-icon name="podium-outline" class="me-2 text-primary fs-4"></ion-icon> Top Wira
                    </h6>
                </div>

                @{ var leaderboard = ViewBag.Leaderboard as List<User> ?? new List<User>(); }
                @foreach (var topUser in leaderboard.Take(1))
                {
                    <div class="leaderboard-item d-flex align-items-center p-3 mb-2 rounded-4 bg-white shadow-sm border border-light">
                        <ion-icon name="star" class="text-warning me-3 fs-4"></ion-icon>
                        <div class="flex-grow-1">
                            <span class="d-block small fw-bold text-dark">@topUser.FullName</span>
                            <small class="text-muted">ID: #@topUser.Id</small>
                        </div>
                        <div class="text-end">
                            <span class="badge bg-primary rounded-pill">Aktif</span>
                        </div>
                    </div>
                }
            </div>
        </a>
    </div>

    <!-- 3. MAIN AREA: MISSION MAP -->
    <div class="col-md-8">
        <div class="card p-4 rounded-5 border-0 shadow-sm h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold m-0 d-flex align-items-center">
                    <ion-icon name="map" class="me-2 text-primary fs-3"></ion-icon> Peta Misi Utama
                </h5>
            </div>

            @if (allModules.Any())
            {
                foreach (var mod in allModules)
                {
                    bool isCompleted = completedIds.Contains(mod.Id);

                    <div class="p-4 bg-light rounded-5 d-flex justify-content-between align-items-center mb-3 mission-item @(isCompleted ? "" : "border-start border-primary border-5")">
                        <div class="d-flex align-items-center gap-3">
                            <div class="icon-box bg-white @(isCompleted ? "text-success" : "text-primary") shadow-sm">
                                <ion-icon name="@(isCompleted ? "checkmark-circle" : "rocket-outline")" style="font-size: 2rem;"></ion-icon>
                            </div>
                            <div>
                                <span class="fw-bold fs-5 d-block text-dark">@mod.Title</span>
                                <div class="d-flex gap-2 align-items-center mt-1">
                                    <span class="badge @(isCompleted ? "bg-success" : "bg-primary") rounded-pill px-2">
                                        @(isCompleted ? "Selesai" : "Misi Aktif")
                                    </span>
                                    <small class="text-muted d-flex align-items-center gap-1">
                                        <ion-icon name="flash-outline"></ion-icon> +50 XP
                                    </small>
                                </div>
                            </div>
                        </div>

                        @if (isCompleted)
                        {
                            <div class="text-end">
                                <div class="bg-success text-white rounded-circle d-inline-flex p-2 mb-1 shadow-sm">
                                    <ion-icon name="sparkles" class="fs-5"></ion-icon>
                                </div>
                                <small class="d-block fw-bold text-success">TERBAIK</small>
                            </div>
                        }
                        else
                        {
                            <a href="@Url.Action("Study", "Dashboard", new { id = mod.Id })" class="btn btn-primary rounded-pill px-4 py-2 fw-bold shadow">
                                MULA <ion-icon name="zap" class="ms-1"></ion-icon>
                            </a>
                        }
                    </div>
                }
            }
            else
            {
                <p class="text-center text-muted">Tiada misi tersedia buat masa ini.</p>
            }
        </div>
    </div>
</div>

<script>
    (function () {
        document.addEventListener("DOMContentLoaded", function () {
            // 1. Ambil data dari C# secara selamat
            var currentXP = Number('@currentXP');
            var nextXP = Number('@nextRankXP');
            var percentage = nextXP > 0 ? (currentXP / nextXP) * 100 : 0;

            // 2. Animasi Pergerakan Bar
            var bar = document.getElementById('ali-xp-bar');
            if (bar instanceof HTMLElement) {
                const safeBar = bar;
                // Timeout sedikit supaya mata nampak pergerakan bermula dari 0
                setTimeout(function() {
                    safeBar.style.width = Math.min(percentage, 100) + "%";
                }, 500);
            }

            // 3. Animasi Nombor Berjalan
            var counter = document.getElementById('ali-xp-counter');
            if (counter instanceof HTMLElement) {
                const safeCounter = counter;
                var start = 0;
                var duration = 1500;
                var increment = currentXP / (duration / 16);

                var timer = setInterval(function() {
                    start += increment;
                    if (start >= currentXP) {
                        safeCounter.innerText = String(Math.floor(currentXP));
                        clearInterval(timer);
                    } else {
                        safeCounter.innerText = String(Math.floor(start));
                    }
                }, 16);
            }
        });
    })();
</script>