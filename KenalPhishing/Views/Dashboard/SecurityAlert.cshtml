@model IEnumerable<KenalPhishing.Models.SecurityAlert>
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Pusat Ancaman (Radar)";
    var verifiedReports = (List<KenalPhishing.Models.ScamReport>)ViewBag.VerifiedReports;
}

<div class="container-fluid py-4">
    <!-- Header: Search & Status -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-0">Radar Ancaman Siber</h2>
            <p class="text-muted">Data masa nyata ancaman phishing di Malaysia.</p>
        </div>
        <div class="status-indicator px-4 py-2 bg-danger bg-opacity-10 text-danger rounded-pill fw-bold border border-danger">
            <span class="dot-animation"></span> STATUS: BERISIKO TINGGI
        </div>
    </div>

    <!-- Search Bar -->
    <div class="card border-0 shadow-sm rounded-4 p-3 mb-5">
        <div class="input-group">
            <span class="input-group-text bg-transparent border-0"><ion-icon name="search-outline" class="fs-4"></ion-icon></span>
            <input type="text" id="radarSearch" class="form-control border-0" placeholder="Cari nombor telefon, pautan palsu, atau taktik scam...">
        </div>
    </div>

    <div class="row g-4">
        <!-- BAHAGIAN KIRI: Amaran Rasmi Admin -->
        <div class="col-lg-7">
            <h5 class="fw-bold mb-4">Amaran Rasmi & Analisis</h5>
            <!-- Bahagian Kiri: Amaran Rasmi -->
            @foreach (var alert in Model)
            {
                <div class="alert-card card mb-4 border-0 border-start border-5 @(alert.Severity == "Tinggi" ? "border-danger" : "border-warning") shadow-sm rounded-4 overflow-hidden">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge @(alert.Severity == "Tinggi" ? "bg-danger" : "bg-warning text-dark") text-uppercase">RASMI</span>
                            <small class="text-muted">@alert.DatePublished.ToString("dd MMM yyyy")</small>
                        </div>
                        <h5 class="fw-bold mb-1">@alert.Title</h5>
                        <div class="mb-3">
                            <small class="text-danger fw-bold"><ion-icon name="warning-outline"></ion-icon> IDENTITI: @alert.ScammerInfo</small>
                        </div>
                        <p class="text-muted small text-truncate">@alert.Content</p>
                        <a href="@Url.Action("SecurityAlert", "Dashboard", new { id = alert.Id })" class="btn btn-sm btn-dark rounded-pill px-4 mt-2">
                            Lihat Analisis Penuh
                        </a>
                    </div>
                </div>
            }
        </div>

        <!-- BAHAGIAN KANAN: Laporan Komuniti (Verified) -->
        <div class="col-lg-5">
            <h5 class="fw-bold mb-4">Laporan Komuniti Tersah</h5>
            <div class="list-group rounded-4 shadow-sm border-0">
                @if (ViewBag.VerifiedReports != null)
                {
                    foreach (var report in ViewBag.VerifiedReports as List<KenalPhishing.Models.ScamReport>)
                    {
                        <div class="report-card card border-0 shadow-sm rounded-4 mb-3 overflow-hidden">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="badge bg-success-subtle text-success small">VERIFIED</span>
                                    <small class="text-muted">@report.DateReported.ToString("dd/MM")</small>
                                </div>

                                <h6 class="text-danger fw-bold mb-1">@report.ScammerInfo</h6>
                                <p class="small text-muted mb-2">Taktik: @report.Category</p>

                                <!-- TAMBAHAN: Paparan Kronologi untuk Pengguna -->
                                <div class="mt-2 p-2 bg-light rounded border-start border-3 border-danger shadow-sm">
                                    <label class="d-block fw-bold text-dark mb-1" style="font-size: 10px; text-transform: uppercase;">Kronologi Kes:</label>
                                    <p class="mb-0 text-secondary" style="font-size: 0.85rem; line-height: 1.4; white-space: pre-line;">
                                        "@report.Description"
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<style>
    .dot-animation {
        height: 10px;
        width: 10px;
        background-color: #dc3545;
        border-radius: 50%;
        display: inline-block;
        margin-right: 8px;
        animation: blink 1s infinite;
    }

    @@keyframes blink {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }

        100% {
            opacity: 1;
        }
    }

    .border-start {
        border-left-width: 8px !important;
    }
</style>

@section Scripts {
    <script>
    document.addEventListener("DOMContentLoaded", function () {
        // Gunakan casting atau semakan null untuk memuaskan IntelliSense
        const searchInput = document.getElementById('radarSearch');

        // Semak jika searchInput wujud dan jenisnya adalah input
        if (searchInput instanceof HTMLInputElement) {
            searchInput.addEventListener('keyup', function () {
                const searchTerm = searchInput.value.toLowerCase();

                // 1. Tapis Amaran Rasmi (Sebelah Kiri)
                const alertCards = document.querySelectorAll('.alert-card');
                alertCards.forEach(function (card) {
                    // Tukar Element kepada HTMLElement supaya .style boleh dibaca
                    if (card instanceof HTMLElement) {
                        const text = (card.textContent || "").toLowerCase();
                        if (text.includes(searchTerm)) {
                            card.style.display = "";
                        } else {
                            card.style.display = "none";
                        }
                    }
                });

                // 2. Tapis Laporan Komuniti (Sebelah Kanan)
                const reportCards = document.querySelectorAll('.report-card');
                reportCards.forEach(function (card) {
                    if (card instanceof HTMLElement) {
                        const text = (card.textContent || "").toLowerCase();
                        if (text.includes(searchTerm)) {
                            card.style.display = "";
                        } else {
                            card.style.display = "none";
                        }
                    }
                });
            });
        }
    });
    </script>
}