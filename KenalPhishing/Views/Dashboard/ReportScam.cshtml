@model KenalPhishing.Models.ScamReport
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Buat Laporan Scam";
}

<div class="container-fluid py-4">
    <div class="mb-5">
        <h2 class="fw-bold">Buat Laporan</h2>
        <p class="text-muted">Laporan anda membantu komuniti mengesan trend scam terkini.</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card p-4 shadow-sm border-0 rounded-4">
                <h6 class="fw-bold mb-4">Borang Laporan Scam Phishing</h6>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm mb-4" role="alert">
                        <ion-icon name="checkmark-circle-outline" class="align-middle me-2 fs-4"></ion-icon>
                        @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm mb-4" role="alert">
                        <ion-icon name="alert-circle-outline" class="align-middle me-2 fs-4"></ion-icon>
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @using (Html.BeginForm("SubmitReport", "Dashboard", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Kategori Scam</label>
                        @Html.DropDownListFor(m => m.Category, new SelectList(new[] { "WhatsApp", "SMS", "E-mel", "Panggilan Telefon", "Lain-lain" }), "Pilih Kategori", new { @class = "form-select", required = "required" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Pautan / No. Telefon Scammer</label>
                        @Html.TextBoxFor(m => m.ScammerInfo, new { @class = "form-control", placeholder = "Contoh: https://bank-palsu.com atau 012-XXXXXXX", required = "required" })
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold">Perihal Kes (Kronologi)</label>
                        @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = "5", placeholder = "Terangkan bagaimana anda menerima mesej ini...", required = "required" })
                        @Html.ValidationMessageFor(m => m.Description, "", new { @class = "text-danger small" })
                    </div>

                    @Html.ValidationSummary(true, "", new { @class = "text-danger small" })

                    <button type="submit" class="btn btn-dark rounded-pill px-5 fw-bold shadow-sm">Hantar Laporan</button>
                }
            </div>

            <!-- DISCLAIMER -->
            <div class="alert alert-light border mt-4 small rounded-3">
                <ion-icon name="information-circle-outline" class="align-middle me-1"></ion-icon>
                <b>Nota:</b> Laporan ini adalah untuk tujuan kesedaran komuniti KenalPhishing sahaja. Untuk tindakan undang-undang, sila hubungi <b>997 (NSRC)</b>.
            </div>
        </div>

  <!-- Sambungan Bahagian Kanan (Hubungi 997) -->
        <div class="col-lg-5">
            <div class="card bg-danger text-white p-4 shadow-sm border-0 rounded-4 mb-4">
                <div class="d-flex align-items-center mb-3">
                    <ion-icon name="call" class="fs-1 me-3"></ion-icon>
                    <h5 class="fw-bold mb-0">Kecemasan Scam?</h5>
                </div>
                <p>Jika anda baru sahaja menjadi mangsa transaksi wang, hubungi <b>997</b> (NSRC) dengan segera dalam tempoh 24 jam.</p>
            </div>

            <div class="card p-4 shadow-sm border-0 rounded-4">
                <h6 class="fw-bold mb-3">Tips Melapor</h6>
                <ul class="small text-muted ps-3">
                    <li>Sertakan pautan penuh (contoh: bit.ly/xxx).</li>
                    <li>Nyatakan modus operandi yang digunakan.</li>
                    <li>Jangan kongsi maklumat peribadi anda di sini.</li>
                </ul>
            </div>
        </div>
    </div>
</div>