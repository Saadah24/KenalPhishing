@model IEnumerable<KenalPhishing.Models.CertificateViewModel>

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Senarai Sijil";
}

<h3 class="fw-bold mb-4">Galeri Sijil Pencapaian</h3>

@foreach (var cert in Model)
{
    if (cert.IsCompleted)
    {
        <!-- Sijil Selesai -->
        <div class="cert-item-card p-4 mb-3 d-flex align-items-center gap-4 shadow-sm bg-white rounded-4 border-start border-5 border-success">
            <div class="cert-icon-box bg-warning text-dark p-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                <ion-icon name="ribbon" class="fs-2"></ion-icon>
            </div>
            <div class="flex-grow-1">
                <h5 class="fw-bold mb-1">@cert.ModuleTitle</h5>
                <p class="small text-muted mb-0">Diterbitkan: @cert.CompletedDate.Value.ToString("dd MMM yyyy") | Skor: @cert.Score%</p>
            </div>
            <div class="d-flex gap-2">
                <a href="@Url.Action("CertificateDetail", "Dashboard", new { id = cert.ModuleId })" class="btn btn-dark rounded-pill px-4 btn-sm">Lihat Sijil</a>
            </div>
        </div>
    }
    else
    {
        <!-- Sijil Belum Selesai (Locked) -->
        <div class="cert-item-card p-4 mb-3 d-flex align-items-center gap-4 opacity-50 bg-light rounded-4 border">
            <div class="cert-icon-box bg-secondary text-white p-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                <ion-icon name="lock-closed" class="fs-2"></ion-icon>
            </div>
            <div class="flex-grow-1">
                <h5 class="fw-bold mb-1">@cert.ModuleTitle</h5>
                <p class="small text-muted mb-0">Status: Belum Selesai (Selesaikan Modul untuk buka)</p>
            </div>
            <div class="d-flex gap-2">
                <a href="@Url.Action("Study", "Dashboard", new { id = cert.ModuleId })" class="btn btn-outline-secondary rounded-pill px-4 btn-sm">Mula Belajar</a>
            </div>
        </div>
    }
}