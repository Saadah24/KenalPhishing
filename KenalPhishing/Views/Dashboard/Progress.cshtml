@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var cat = ViewBag.Category;
    var avgScore = ViewBag.AvgScore ?? 0;

    // Logik Warna Lampu Isyarat & Aromaterapi
    string statusColor = avgScore >= 80 ? (cat == "Elder" ? "#2D6A4F" : "#198754")
                                       : (avgScore >= 50 ? "#D97706" : "#991B1B");

    string statusText = avgScore >= 80 ? "Sangat Baik" : (avgScore >= 50 ? "Sederhana" : "Perlu Perhatian");
    var progressStyle = "width: " + avgScore + "%; background-color: " + statusColor + ";";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;700&family=Baloo+2:wght@700;800&display=swap" rel="stylesheet">

<style>
    :root {
        --elder-navy: #1A365D;
        --elder-green: #2D6A4F;
        --elder-blue: #0056B3;
        --elder-amber: #D97706;
        --elder-bg: #F8FAFC;
        --tactile-border: 2px solid #E2E8F0; /* Diselaraskan kepada border kelabu neutral lembut */
    }

    body {
        background-color: #f0f2f5;
        font-family: 'Inter', sans-serif;
    }

    .card {
        border: none;
        transition: all 0.3s ease;
    }

    .card-hover:hover, .cert-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        cursor: pointer;
    }

    .rounded-5 {
        border-radius: 2rem !important;
    }

    .rounded-4 {
        border-radius: 1.2rem !important;
    }

    /* Kemaskini Kad Gaya Warga Emas yang Lebih Seimbang */
    .elder-card {
        background: white;
        border: var(--tactile-border);
        border-radius: 1.5rem;
        box-shadow: 0 4px 0px rgba(226, 232, 240, 0.8);
        transition: all 0.2s ease;
    }

    .elder-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(0,0,0,0.05);
    }

    .bg-gradient-blue {
        background: linear-gradient(135deg, #0d6efd, #00d2ff);
    }

    .bg-primary-soft { background: rgba(13, 110, 253, 0.1); }
    .bg-warning-soft { background: rgba(217, 119, 6, 0.1); }
    .bg-info-soft { background: rgba(13, 202, 240, 0.1); }

    .animate-float {
        animation: floating 3s infinite ease-in-out;
    }

    .cert-link-hover {
        color: var(--elder-navy);
        transition: opacity 0.3s ease;
    }

    .cert-link-hover:hover {
        opacity: 0.7;
    }

    @* Menghalang ralat kompilasi Razor dengan menggunakan @@ *@
    @@keyframes floating {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-10px) rotate(3deg); }
    }
</style>

<div class="container-fluid py-3">

    @* ==========================================
         SKIN 1: CHILD (WIRA SIBER)
        ========================================== *@
    @if (cat == "Child")
    {
        <div class="skin-child" style="font-family: 'Baloo 2', cursive;">
            <div class="card border-0 rounded-5 shadow-sm mb-5 overflow-hidden bg-gradient-blue text-white position-relative">
                <div class="card-body p-5 position-relative" style="z-index: 2;">
                    <div class="row align-items-center">
                        <div class="col-md-8 text-center text-md-start">
                            <h1 class="display-5 fw-bold mb-2">Rekod Perjuangan Wira @ViewBag.UserName! 🚀</h1>
                            <p class="fs-5 opacity-75">Kumpul XP untuk naik pangkat dan jadi Jeneral Siber!</p>
                            <div class="mt-4">
                                <div class="d-flex justify-content-between mb-1 fw-bold">
                                    <span>XP Anda: @(ViewBag.CurrentXP ?? 0) / @(ViewBag.NextRankXP ?? 100)</span>
                                </div>
                                <div class="progress rounded-pill bg-white bg-opacity-25" style="height: 20px;">
                                    @{
                                        double childProgress = ViewBag.NextRankXP > 0 ? ((double)ViewBag.CurrentXP / ViewBag.NextRankXP) * 100 : 0;
                                        string inlineProgressStyle = $"width: {childProgress}%;";
                                    }
                                    <div class="progress-bar bg-warning progress-bar-striped progress-bar-animated" style="@inlineProgressStyle"></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 text-center d-none d-md-block">
                            <ion-icon name="rocket" style="font-size: 150px;" class="animate-float"></ion-icon>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-5 text-center">
                <div class="col-md-4">
                    <a href="@Url.Action("Pangkat", "Dashboard")" class="text-decoration-none text-dark">
                        <div class="card border-0 shadow rounded-5 p-4 bg-white h-100 card-hover">
                            <div class="icon-circle bg-primary-soft mx-auto mb-3 text-primary"><ion-icon name="trophy" class="display-4"></ion-icon></div>
                            <h4 class="fw-bold">@(ViewBag.LevelName ?? "Prajurit Muda")</h4>
                            <p class="text-muted small mb-0">PANGKAT (Klik)</p>
                        </div>
                    </a>
                </div>
                <div class="col-md-4">
                    <a href="@Url.Action("Lencana", "Dashboard")" class="text-decoration-none text-dark">
                        <div class="card border-0 shadow rounded-5 p-4 bg-white h-100 card-hover">
                            <div class="icon-circle bg-warning-soft mx-auto mb-3 text-warning"><ion-icon name="medal" class="display-4"></ion-icon></div>
                            <h4 class="fw-bold">@(ViewBag.Badges ?? 0) Lencana</h4>
                            <p class="text-muted small mb-0">KOLEKSI (Klik)</p>
                        </div>
                    </a>
                </div>
                <div class="col-md-4">
                    <a href="@Url.Action("Ranking", "Dashboard")" class="text-decoration-none text-dark">
                        <div class="card border-0 shadow rounded-5 p-4 bg-white h-100 card-hover">
                            <div class="icon-circle bg-info-soft mx-auto mb-3 text-info"><ion-icon name="people" class="display-4"></ion-icon></div>
                            <h4 class="fw-bold">No. @(ViewBag.Rank ?? 1)</h4>
                            <p class="text-muted small mb-0">RANKING DUNIA (Klik)</p>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    }
    @* ==========================================
         SKIN 2: ELDER (TACTILE & WARM) - DIKEMASKINI
        ========================================== *@
    else if (cat == "Elder")
    {
        <div class="skin-elder">
            <!-- Hero Header diubah daripada p-5 ke p-4, dan teks lebih seimbang -->
            <div class="elder-card p-4 mb-4" style="background: linear-gradient(135deg, #E0F2FE 0%, #FFFFFF 100%); border-color: #BAE6FD;">
                <div class="row align-items-center text-center text-md-start">
                    <div class="col-md-auto mb-3 mb-md-0 text-center">
                        <div class="p-2 bg-white rounded-circle shadow-sm d-inline-block border border-3 border-info">
                            <ion-icon name="person-circle" style="font-size: 64px; color: var(--elder-navy); display: block;"></ion-icon>
                        </div>
                    </div>
                    <div class="col-md">
                        <h1 class="fs-2 fw-bold mb-1" style="color: var(--elder-navy);">Laporan Anda, Tuan/Puan @ViewBag.UserName</h1>
                        <p class="fs-5 text-secondary mb-0">Semuanya dalam keadaan selamat hari ini. Syabas!</p>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-7">
                    <!-- Ditukar dari p-5 ke p-4 -->
                    <div class="elder-card p-4 h-100 text-center">
                        <h2 class="mb-4 fs-3 fw-bold text-navy">Tahap Keselamatan Anda</h2>
                        <div class="position-relative mb-3">
                            <h1 class="fw-bold mb-0" style="color: @statusColor; font-size: 4rem;">@avgScore%</h1>
                            <p class="fs-3 fw-bold mb-2" style="color: @statusColor">@statusText</p>
                        </div>
                        <div class="progress rounded-pill mb-3" style="height: 35px; background-color: #E2E8F0; border: 2px solid #CBD5E1;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" style="@progressStyle"></div>
                        </div>
                        <p class="fs-5 mt-3 mb-0">
                            <ion-icon name="information-circle" class="text-primary fs-3 align-middle"></ion-icon> Lengkapkan semua modul untuk kekal dilindungi.
                        </p>
                    </div>
                </div>

                <div class="col-lg-5">
                    <!-- Ditukar dari p-5 ke p-4 dan warna sempadan sekata menggunakan warna neutral kelabu -->
                    <div class="elder-card p-4 h-100">
                        <h2 class="mb-4 fs-3 fw-bold text-navy">Pencapaian</h2>
                        <div class="row g-3">
                            <div class="col-6 text-center">
                                <div class="p-3 rounded-4 bg-white border" style="border-color: #E2E8F0 !important;">
                                    <ion-icon name="ribbon" style="font-size: 3rem; color: var(--elder-amber);"></ion-icon>
                                    <h2 class="fw-bold mb-0 fs-3 mt-2">@(ViewBag.ModulesFinished ?? 0)</h2>
                                    <span class="fs-6 fw-bold text-muted text-uppercase">Modul Siap</span>
                                </div>
                            </div>
                            <div class="col-6 text-center">
                                <div class="p-3 rounded-4 bg-white border" style="border-color: #E2E8F0 !important;">
                                    <ion-icon name="document-text" style="font-size: 3rem; color: var(--elder-blue);"></ion-icon>
                                    <h2 class="fw-bold mb-0 fs-3 mt-2">@(ViewBag.Certificates ?? 0)</h2>
                                    <span class="fs-6 fw-bold text-muted text-uppercase">Sijil</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    @* ==========================================
         SKIN 3: ADULT (ANALYTICAL)
        ========================================== *@
    else
    {
        <div class="skin-adult">
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold text-dark mb-1">Laporan Analitik Prestasi</h2>
                    <p class="text-muted small"><ion-icon name="stats-chart-outline"></ion-icon> Metrik bagi @ViewBag.UserName</p>
                </div>
                <div class="d-flex gap-2">
                    <div class="badge-hexagon d-flex align-items-center gap-2 px-3 py-2 text-primary bg-primary bg-opacity-10 border border-primary rounded-3">
                        <ion-icon name="ribbon" class="fs-4"></ion-icon><span class="fw-bold">@statusText</span>
                    </div>
                    <a href="@Url.Action("ExportProgressCsv", "Dashboard")" class="btn btn-primary rounded-pill px-4 shadow-sm">
                        <ion-icon name="download-outline" class="me-1"></ion-icon> Eksport .CSV
                    </a>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-lg-4">
                    <div class="card border-start border-5 border-primary shadow-sm rounded-4 p-4 h-100">
                        <h6 class="text-muted fw-bold small">SKOR PURATA</h6>
                        <h1 class="display-4 fw-bold text-dark my-2">@avgScore%</h1>
                        <div class="progress rounded-pill" style="height: 8px;"><div class="progress-bar bg-primary" style="@progressStyle"></div></div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card shadow-sm rounded-4 p-4 h-100 bg-white">
                        <h6 class="text-muted fw-bold small">MASA BELAJAR</h6>
                        @{
                            int totalMins = ViewBag.TotalStudyTime ?? 0;
                            int hours = totalMins / 60;
                            int mins = totalMins % 60;
                        }
                        <h1 class="display-4 fw-bold text-dark my-2">@hours j @mins m</h1>
                        <p class="text-muted small mb-0">Jumlah pelaburan masa</p>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card shadow-sm rounded-4 p-4 h-100 bg-white">
                        <h6 class="text-muted fw-bold small">ANALISIS TOPIK</h6>
                        <div style="height: 150px;"><canvas id="adultRadarChart"></canvas></div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm rounded-4 p-4 mb-4">
                <h6 class="fw-bold mb-4">Trend Kesedaran (6 Bulan)</h6>
                <div style="height: 250px;"><canvas id="performanceTrendChart"></canvas></div>
            </div>
        </div>
    }

    @* --- SHARED CERTIFICATE GALLERY --- *@
    <div class="mt-4 border-top pt-4">
        <h3 class="fw-bold mb-4 fs-3 text-navy">
            <a href="@Url.Action("Certificates", "Dashboard")" class="text-decoration-none cert-link-hover">
                <ion-icon name="ribbon-outline" class="text-warning"></ion-icon> Galeri Sijil Digital
                <ion-icon name="open-outline" class="fs-6 ms-1 text-muted"></ion-icon>
            </a>
        </h3>

        <div class="row g-3">
            @if (ViewBag.CompletedCerts != null)
            {
                var certs = (IEnumerable<KenalPhishing.Models.UserProgress>)ViewBag.CompletedCerts;
                if (certs.Any())
                {
                    foreach (var cert in certs)
                    {
                        <div class="col-md-3 col-6">
                            <div class="card shadow-sm rounded-4 overflow-hidden cert-card h-100 border">
                                <div class="bg-light p-3 text-center border-bottom">
                                    <ion-icon name="ribbon" class="fs-1 text-primary opacity-50"></ion-icon>
                                </div>
                                <div class="p-3 bg-white text-center">
                                    <h6 class="fw-bold mb-1 text-truncate">@cert.Module.Title</h6>
                                    <a href="@Url.Action("CertificateDetail", "Dashboard", new { id = cert.ModuleId })" class="btn btn-sm btn-outline-primary w-100 rounded-pill mt-2">
                                        Muat Turun
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center text-muted p-5 bg-light rounded-4 border">
                        <ion-icon name="document-text-outline" class="display-4 mb-2 opacity-25"></ion-icon>
                        <p class="mb-0 fs-5">Belum ada sijil yang diraih. Selesaikan modul untuk dapatkan sijil!</p>
                    </div>
                }
            }
        </div>
    </div>
</div>

@* Data Block *@
@if (cat == "Adult")
{
    <script type="application/json" id="chartDataStore">
    {
        "radarLabels": @Html.Raw(Json.Encode(ViewBag.RadarLabels ?? new string[] { "Belum Ada Rekod" })),
        "radarData": @Html.Raw(Json.Encode(ViewBag.RadarValues ?? new int[] { 0 })),
        "lineLabels": @Html.Raw(Json.Encode(ViewBag.LineLabels ?? new string[] { })),
        "lineData": @Html.Raw(Json.Encode(ViewBag.LineValues ?? new int[] { }))
    }
    </script>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var currentCategory = '@(cat ?? "Adult")';
            if (currentCategory === "Adult") {
                var storeEl = document.getElementById('chartDataStore');
                if (storeEl) {
                    var dataStore = JSON.parse(storeEl.textContent);
                    var radarLabels = dataStore.radarLabels;
                    var radarData = dataStore.radarData;
                    var lineLabels = dataStore.lineLabels;
                    var lineData = dataStore.lineData;

                    var radarCanvas = document.getElementById('adultRadarChart');
                    var radarConfig = {
                        type: 'radar',
                        data: {
                            labels: radarLabels,
                            datasets: [{ label: 'Kecekapan (%)', data: radarData, backgroundColor: 'rgba(13, 110, 253, 0.2)', borderColor: '#0d6efd', pointBackgroundColor: '#0d6efd' }]
                        },
                        options: { maintainAspectRatio: false, scales: { r: { suggestMin: 0, suggestMax: 100, ticks: { display: false } } }, plugins: { legend: { display: false } } }
                    };

                    var lineCanvas = document.getElementById('performanceTrendChart');
                    var lineConfig = {
                        type: 'line',
                        data: {
                            labels: lineLabels,
                            datasets: [{ label: 'Skor Kesedaran (%)', data: lineData, borderColor: '#0d6efd', backgroundColor: 'rgba(13, 110, 253, 0.1)', fill: true, tension: 0.4 }]
                        },
                        options: { maintainAspectRatio: false, scales: { y: { beginAtZero: true, max: 100 } } }
                    };

                    try {
                        var createChart = new Function('el', 'cfg', 'if(typeof Chart !== "undefined") { new Chart(el, cfg); }');
                        if (radarCanvas && radarData.length > 0) createChart(radarCanvas, radarConfig);
                        if (lineCanvas && lineData.length > 0) createChart(lineCanvas, lineConfig);
                    } catch (e) { console.error("Gagal membina carta:", e); }
                }
            }
        });
    </script>
}