@model KenalPhishing.Models.SecurityAlert
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Buletin Keselamatan";
}

@section Styles {
    <style>
        /* 1. Pastikan sidebar berada di lapisan paling atas */
        .sidebar {
            z-index: 1050 !important;
        }

        /* 2. Pastikan content-wrapper tidak 'melimpah' ke atas sidebar */
        .content-wrapper {
            position: relative;
            z-index: 1;
        }

        /* 3. Elakkan shadow card menindih elemen lain */
        .card.shadow-lg {
            z-index: 2;
            position: relative;
        }

        /* 4. Pastikan pautan kembali boleh diklik */
        .back-link-area {
            position: relative;
            z-index: 10;
        }
    </style>
}

<div class="container py-4">
    <div class="mb-4 d-flex justify-content-between align-items-center back-link-area">
        <a href="@Url.Action("SecurityAlert", "Dashboard", new { id = "" })" class="text-muted text-decoration-none small d-flex align-items-center">
            <ion-icon name="arrow-back-outline" class="me-1"></ion-icon>
            <span>Kembali ke Radar</span>
        </a>
        <span class="badge bg-dark">LAPORAN #SC-@Model.Id</span>
    </div>

    <!-- START PROFESSIONAL TEMPLATE -->
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <!-- Header -->
        <div class="bg-dark p-4 p-md-5 text-white">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1 class="fw-bold mb-2">@Model.Title</h1>
                    <p class="mb-0 opacity-75 small">Diterbitkan: @Model.DatePublished.ToString("dd MMMM yyyy") | Oleh: Pasukan Keselamatan KenalPhishing</p>
                </div>
                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                    <div class="d-inline-block p-3 bg-danger rounded-4 text-center">
                        <small class="d-block text-uppercase fw-bold" style="font-size: 10px;">Tahap Risiko</small>
                        <h4 class="fw-bold mb-0">@Model.Severity.ToUpper()</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-body p-4 p-md-5 bg-white">
            <div class="row g-4">

                <!-- KOTAK BUKTI MESEJ -->
                <div class="col-lg-7">
                    <div class="p-4 border rounded-4 bg-light h-100">
                        <h6 class="fw-bold mb-3 text-muted"><ion-icon name="mail-open-outline" class="me-1"></ion-icon> [!] BUKTI MESEJ (CONTOH SCAM)</h6>
                        <div class="bg-white p-3 rounded-3 border-start border-4 border-danger shadow-sm">
                            <p class="mb-0 fw-bold text-dark" style="font-family: 'Courier New', Courier, monospace; letter-spacing: -0.5px;">
                                "@Model.ExampleMessage"
                            </p>
                        </div>
                        <p class="mt-3 small text-danger fw-bold"><ion-icon name="alert-circle"></ion-icon> DILARANG KLIK SEBARANG PAUTAN DI ATAS</p>
                    </div>
                </div>

                <!-- INFO ANCAMAN -->
                <div class="col-lg-5">
                    <div class="p-4 border rounded-4 bg-light h-100">
                        <h6 class="fw-bold mb-3 text-muted"><ion-icon name="finger-print-outline" class="me-1"></ion-icon> [ INFO ANCAMAN ]</h6>
                        <ul class="list-unstyled">
                            <li class="mb-3">
                                <label class="d-block small text-muted fw-bold">IDENTITI PENGIRIM / URL:</label>
                                <code class="fs-5 text-danger fw-bold">@Model.ScammerInfo</code>
                            </li>
                            <li class="mb-3">
                                <label class="d-block small text-muted fw-bold">KATEGORI:</label>
                                <span class="badge bg-dark">
                                    Phishing @(Model.Title != null ? Model.Title.Split(' ').Last() : "Umum")
                                </span>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Bahagian Analisis Keselamatan -->
                <div class="col-12">
                    <div class="p-4 border rounded-4 shadow-sm bg-white border-start border-5 border-primary">
                        <h5 class="fw-bold mb-3 text-primary"><ion-icon name="analytics-outline" class="me-2"></ion-icon>Analisis Keselamatan (Pakar)</h5>

                        @* Gunakan white-space pre-line berbanding Html.Raw jika anda tidak mahu HTML merosakkan layout *@
                        <div style="line-height: 1.8; color: #444; white-space: pre-line;">
                            @Model.Content
                        </div>
                    </div>
                </div>

            </div>

            <!-- ACTION BUTTONS -->
            <div class="row mt-5">
                <div class="col-md-6 mb-2">
                    <a href="tel:997" class="btn btn-danger w-100 py-3 rounded-pill fw-bold shadow-sm">
                        <ion-icon name="call-outline" class="me-2"></ion-icon> LAPOR KE NSRC (997)
                    </a>
                </div>
                <div class="col-md-6 mb-2">
                    <a href="https://wa.me/?text=Amaran Scam Terkini: @(Model.Title ?? "Amaran Baharu"). Sila semak di KenalPhishing!" class="btn btn-success w-100 py-3 rounded-pill fw-bold shadow-sm">
                        <ion-icon name="logo-whatsapp" class="me-2"></ion-icon> KONGSI KE WHATSAPP
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>