@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Guna layout sidebar
    ViewBag.Title = "Pengurusan Modul";
}

@section Styles {
    <link href="~/Content/Admin.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/Dashboard.css" rel="stylesheet" type="text/css" />
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Senarai Modul</h2>
        <a href="@Url.Action("EditModule", "Admin")" class="btn btn-dark rounded-pill px-4">
            <ion-icon name="add-outline" class="me-2"></ion-icon> Tambah Modul Baharu
        </a>
    </div>

    <div class="admin-table-card shadow-sm overflow-hidden">
        <table class="table table-hover mb-0">
            <thead class="bg-black text-white">
                <tr>
                    <th>Tajuk Modul</th>
                    <th>Kategori</th>
                    <th>Tahap</th>
                    <th>Tarikh Kemaskini</th>
                    <th class="text-center">Tindakan</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="fw-bold">Asas Phishing</td>
                    <td><span class="badge bg-elder text-dark">Warga Emas</span></td>
                    <td>Mudah</td>
                    <td>11 Jan 2025</td>
                    <td class="text-center">
                        <a href="@Url.Action("EditModule", "Admin", new { id = 1 })" class="btn btn-sm btn-outline-dark me-2">Sunting</a>
                        <button class="btn btn-sm btn-danger" onclick="showAdminPopup('Modul Telah Dihapuskan')">Hapus</button>
                    </td>
                </tr>
                <tr>
                    <td class="fw-bold">Analisis Phishing Advanced</td>
                    <td><span class="badge bg-adult text-dark">Dewasa</span></td>
                    <td>Sederhana</td>
                    <td>10 Jan 2025</td>
                    <td class="text-center">
                        <a href="#" class="btn btn-sm btn-outline-dark me-2">Sunting</a>
                        <button class="btn btn-sm btn-danger">Hapus</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>