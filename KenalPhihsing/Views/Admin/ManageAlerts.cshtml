@model IEnumerable<KenalPhihsing.Models.SecurityAlert>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Urus Amaran";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">Pengurusan Amaran Keselamatan</h3>
        <a href="@Url.Action("EditAlert", "Admin")" class="btn btn-dark rounded-pill">
            <ion-icon name="add-outline"></ion-icon> Tambah Amaran Baru
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Tajuk</th>
                    <th>Tahap</th>
                    <th>Tarikh</th>
                    <th class="text-end">Tindakan</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.Title</td>
                        <td>
                            <span class="badge @(item.Severity == "Tinggi" ? "bg-danger" : "bg-warning text-dark")">@item.Severity</span>
                        </td>
                        <td class="small text-muted">@item.DatePublished.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            <a href="@Url.Action("EditAlert", "Admin", new { id = item.Id })" class="btn btn-sm btn-outline-primary">Edit</a>
                            @using (Html.BeginForm("DeleteAlert", "Admin", new { id = item.Id }, FormMethod.Post, new { @class = "d-inline", onsubmit = "return confirm('Padam amaran ini?');" }))
                            {
                                <button type="submit" class="btn btn-sm btn-outline-danger">Padam</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
