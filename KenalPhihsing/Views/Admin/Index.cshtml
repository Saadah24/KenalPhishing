@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Dashboard Pentadbir";
}

@section Styles {
    <link href="~/Content/Admin.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/Dashboard.css" rel="stylesheet" type="text/css" />
}


<div class="container-fluid">
    <div class="mb-5">
        <h2 class="fw-bold">Ringkasan Pentadbir</h2>
        <p class="text-muted">Selamat datang kembali, Admin. Berikut adalah statistik sistem hari ini.</p>
    </div>

    <!-- Statistik Ringkas -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="p-4 bg-dark text-white rounded-4 shadow-sm">
                <h6 class="small text-uppercase opacity-50">Jumlah Pelajar</h6>
                <h2 class="fw-bold mb-0">1,240</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-4 bg-primary text-white rounded-4 shadow-sm">
                <h6 class="small text-uppercase opacity-50">Modul Aktif</h6>
                <h2 class="fw-bold mb-0">12</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-4 bg-warning text-dark rounded-4 shadow-sm">
                <h6 class="small text-uppercase opacity-50">Laporan Scam</h6>
                <h2 class="fw-bold mb-0">45</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-4 bg-success text-white rounded-4 shadow-sm">
                <h6 class="small text-uppercase opacity-50">Sijil Dikeluarkan</h6>
                <h2 class="fw-bold mb-0">890</h2>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Pautan Pantas -->
        <div class="col-lg-6">
            <div class="card p-4 rounded-4 border-0 shadow-sm h-100">
                <h5 class="fw-bold mb-4">Pautan Pantas</h5>
                <div class="list-group list-group-flush">
                    <a href="@Url.Action("ManageModules", "Admin")" class="list-group-item list-group-item-action border-0 px-0 d-flex align-items-center">
                        <ion-icon name="book-outline" class="me-3 fs-4"></ion-icon> Urus Modul Pembelajaran
                    </a>
                    <a href="#" class="list-group-item list-group-item-action border-0 px-0 d-flex align-items-center">
                        <ion-icon name="people-outline" class="me-3 fs-4"></ion-icon> Urus Senarai Pelajar
                    </a>
                    <a href="#" class="list-group-item list-group-item-action border-0 px-0 d-flex align-items-center">
                        <ion-icon name="alert-circle-outline" class="me-3 fs-4 text-danger"></ion-icon> Semak Laporan Scam
                    </a>
                </div>
            </div>
        </div>

        <!-- Notifikasi Sistem -->
        <div class="col-lg-6">
            <div class="card p-4 rounded-4 border-0 shadow-sm h-100">
                <h5 class="fw-bold mb-4">Notifikasi Sistem</h5>
                <div class="alert alert-info small border-0 rounded-3">
                    <b>Kemas kini:</b> Server akan diselenggara pada jam 12:00 AM malam ini.
                </div>
                <div class="alert alert-warning small border-0 rounded-3">
                    <b>Amaran:</b> Terdapat 5 laporan scam baharu yang memerlukan tindakan.
                </div>
            </div>
        </div>
    </div>
</div>