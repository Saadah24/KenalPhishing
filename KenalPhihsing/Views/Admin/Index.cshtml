@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Dashboard Pentadbir";
}

@section Styles {
    <link href="~/Content/Admin.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/Dashboard.css" rel="stylesheet" type="text/css" />
    <style>
        /* Professional touches for Admin Panel */
        .stat-card {
            position: relative;
            overflow: hidden;
            transition: transform 0.2s;
        }

            .stat-card:hover {
                transform: translateY(-5px);
            }

        .stat-icon {
            position: absolute;
            right: -10px;
            bottom: -10px;
            font-size: 5rem;
            opacity: 0.15;
            transform: rotate(-15deg);
        }

        .extra-small {
            font-size: 0.75rem;
        }

        .trend-up {
            color: #2ecc71;
            font-weight: bold;
        }

        .activity-item {
            transition: background 0.2s;
            cursor: pointer;
        }

            .activity-item:hover {
                background: #f8f9fa;
            }
    </style>
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h2 class="fw-bold mb-1">Ringkasan Pentadbir</h2>
            <p class="text-muted mb-0">Sistem KenalPhishing sedang berjalan lancar.</p>
        </div>
        <div class="text-end d-none d-md-block">
            <div class="small fw-bold text-uppercase text-muted ls-1">Kesihatan Sistem</div>
            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">
                <span class="spinner-grow spinner-grow-sm me-1" role="status"></span> Server: Online
            </span>
        </div>
    </div>

    <!-- Statistik Ringkas (Enhanced with Icons & Trends) -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="p-4 bg-dark text-white rounded-4 shadow-sm stat-card">
                <ion-icon name="people" class="stat-icon"></ion-icon>
                <h6 class="small text-uppercase opacity-50">Jumlah Pelajar</h6>
                <h2 class="fw-bold mb-1">1,240</h2>
                <span class="extra-small trend-up">+5.2% bulan ini</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-4 bg-primary text-white rounded-4 shadow-sm stat-card">
                <ion-icon name="book" class="stat-icon"></ion-icon>
                <h6 class="small text-uppercase opacity-50">Modul Aktif</h6>
                <h2 class="fw-bold mb-1">12</h2>
                <span class="extra-small opacity-75">3 dikemaskini hari ini</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-4 bg-warning text-dark rounded-4 shadow-sm stat-card">
                <ion-icon name="alert-circle" class="stat-icon"></ion-icon>
                <h6 class="small text-uppercase opacity-50 text-dark">Laporan Scam</h6>
                <h2 class="fw-bold mb-1">45</h2>
                <span class="extra-small fw-bold text-danger">8 Belum Disemak</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-4 bg-success text-white rounded-4 shadow-sm stat-card">
                <ion-icon name="ribbon" class="stat-icon"></ion-icon>
                <h6 class="small text-uppercase opacity-50">Sijil Dikeluarkan</h6>
                <h2 class="fw-bold mb-1">890</h2>
                <span class="extra-small opacity-75">98% kadar kelulusan</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- MONITORING: User Registration Trend -->
        <div class="col-lg-8">
            <div class="card p-4 rounded-4 border-0 shadow-sm h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold m-0">Trend Pendaftaran Pelajar</h5>
                    <div class="d-flex gap-2">
                        <select class="form-select form-select-sm w-auto border-0 bg-light">
                            <option>7 Hari Terakhir</option>
                            <option>30 Hari Terakhir</option>
                        </select>
                        <button class="btn btn-light btn-sm rounded-circle"><ion-icon name="download-outline"></ion-icon></button>
                    </div>
                </div>
                <!-- Placeholder for Chart.js Integration -->
                <div style="height: 280px; background: #fcfdfe; border-radius: 20px;" class="d-flex flex-column align-items-center justify-content-center border border-dashed">
                    <ion-icon name="stats-chart" class="fs-1 text-primary opacity-25 mb-2"></ion-icon>
                    <p class="text-muted small">Visualisasi Data (Chart.js)</p>
                    <span class="extra-small text-uppercase ls-1 opacity-50">Menunggu Integrasi API</span>
                </div>
            </div>
        </div>

        <!-- LIVE FEED: Recent Portal Activity -->
        <div class="col-lg-4">
            <div class="card p-4 rounded-4 border-0 shadow-sm h-100">
                <h5 class="fw-bold mb-4">Aktiviti Terkini Portal</h5>
                <div class="activity-feed">
                    <div class="d-flex gap-3 mb-3 pb-3 border-bottom activity-item p-2 rounded-3">
                        <div class="bg-primary bg-opacity-10 p-2 rounded-circle text-primary d-flex align-items-center shadow-sm" style="height:40px; width:40px;">
                            <ion-icon name="person-add" class="mx-auto"></ion-icon>
                        </div>
                        <div>
                            <p class="small mb-0"><b>User99</b> baru mendaftar (Warga Emas)</p>
                            <span class="extra-small text-muted">2 minit lepas</span>
                        </div>
                    </div>
                    <div class="d-flex gap-3 mb-3 pb-3 border-bottom activity-item p-2 rounded-3">
                        <div class="bg-success bg-opacity-10 p-2 rounded-circle text-success d-flex align-items-center shadow-sm" style="height:40px; width:40px;">
                            <ion-icon name="checkmark-done" class="mx-auto"></ion-icon>
                        </div>
                        <div>
                            <p class="small mb-0"><b>Ali1</b> tamat Kuiz Phishing</p>
                            <span class="extra-small text-muted">15 minit lepas</span>
                        </div>
                    </div>
                    <div class="d-flex gap-3 mb-3 pb-3 border-bottom activity-item p-2 rounded-3">
                        <div class="bg-danger bg-opacity-10 p-2 rounded-circle text-danger d-flex align-items-center shadow-sm" style="height:40px; width:40px;">
                            <ion-icon name="alert-circle" class="mx-auto"></ion-icon>
                        </div>
                        <div>
                            <p class="small mb-0"><b>Abu</b> melaporkan Scam baru</p>
                            <span class="extra-small text-muted">1 jam lepas</span>
                        </div>
                    </div>
                </div>
                <div class="mt-auto pt-3">
                    <a href="#" class="btn btn-outline-primary btn-sm w-100 rounded-pill py-2 fw-bold">Lihat Semua Log</a>
                </div>
            </div>
        </div>
    </div>
</div>