@model IEnumerable<KenalPhihsing.Models.ScamReport>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Urus Laporan Scam";
}

<div class="container-fluid py-4">
    <h3 class="fw-bold mb-4">Pengurusan Laporan Scam</h3>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="ps-4">Tarikh</th>
                        <th>Kategori</th>
                        <th>Maklumat Scammer</th>
                        <th>Butiran Kes</th>
                        <th>Status</th> <!-- Kolum Status dikembalikan -->
                        <th class="text-end pe-4">Tindakan</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 small">@item.DateReported.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge rounded-pill bg-info bg-opacity-10 text-dark">@item.Category</span></td>
                            <td class="small text-danger">@item.ScammerInfo</td>

                            <!-- KOLUM BUTIRAN -->
                            <td>
                                <button type="button" class="btn btn-sm btn-light border" data-bs-toggle="modal" data-bs-target="#modal-@item.Id">
                                    <ion-icon name="eye-outline" class="align-middle"></ion-icon> Lihat
                                </button>

                                <!-- MODAL BUTIRAN -->
                                <div class="modal fade text-start" id="modal-@item.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content border-0 rounded-4 shadow">
                                            <div class="modal-header border-0 pb-0">
                                                <h5 class="fw-bold">Butiran Laporan #@item.Id</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body p-4">
                                                <div class="mb-3">
                                                    <label class="small text-muted d-block">Pemberi Maklumat (User ID):</label>
                                                    <span class="fw-bold">@item.UserId</span>
                                                </div>
                                                <div class="mb-3">
                                                    <label class="small text-muted d-block">Maklumat Scammer:</label>
                                                    <span class="text-danger fw-bold">@item.ScammerInfo (@item.Category)</span>
                                                </div>
                                                <hr class="text-muted opacity-25">
                                                <div class="mb-0">
                                                    <label class="small text-muted d-block">Kronologi / Perihal Kes:</label>
                                                    <p class="bg-light p-3 rounded-3 mt-2" style="white-space: pre-line; color: #333; font-size: 0.9rem;">
                                                        @item.Description
                                                    </p>
                                                </div>
                                            </div>
                                            <div class="modal-footer border-0">
                                                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Tutup</button>
                                                @if (item.Status == "Verified")
                                                {
                                                    <a href="@Url.Action("PromoteToAlert", "Admin", new { id = item.Id })" class="btn btn-primary rounded-pill px-4">Terbit Buletin</a>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>

                            <!-- KOLUM STATUS -->
                            <td>
                                @if (item.Status == "Pending")
                                {<span class="badge bg-warning text-dark">Menunggu</span> }
                                else if (item.Status == "Verified")
                                { <span class="badge bg-success">Disahkan</span> }
                                else
                                { <span class="badge bg-danger">Ditolak</span>}
                            </td>

                            <!-- KOLUM TINDAKAN -->
                            <td class="text-end pe-4">
                                @if (item.Status == "Pending")
                                {
                                    using (Html.BeginForm("UpdateStatus", "Admin", FormMethod.Post, new { @class = "d-inline" }))
                                    {
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" name="status" value="Verified" class="btn btn-sm btn-success rounded-pill px-3">Sahkan</button>
                                        <button type="submit" name="status" value="Rejected" class="btn btn-sm btn-outline-danger rounded-pill px-3 ms-1">Tolak</button>
                                    }
                                }
                                else if (item.Status == "Verified")
                                {
                                    <a href="@Url.Action("PromoteToAlert", "Admin", new { id = item.Id })" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm">
                                        <ion-icon name="megaphone-outline" class="align-middle me-1"></ion-icon> Terbit Buletin
                                    </a>
                                }
                                else
                                {
                                    <small class="text-muted">Tiada tindakan</small>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>