@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Kuiz Pengetahuan";
}

@section Styles {
    <link href="~/Content/Quiz.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/Dashboard.css" rel="stylesheet" type="text/css" />
}

<div class="quiz-container py-5">
    <div class="quiz-card p-5 shadow-sm">
        <div class="quiz-header text-center mb-5">
            <h2 class="fw-bold">Uji Pengetahuan Anda</h2>
        </div>

        <form action="@Url.Action("SubmitQuiz", "Dashboard")" method="post">
            <div class="question-block mb-5">
                <h5 class="fw-bold mb-4">1. Antara ciri berikut, yang manakah merupakan tanda amaran utama (Red Flag) dalam emel phishing?</h5>

                <div class="options-grid">
                    <!-- Opsi A -->
                    <label class="option-item">
                        <input type="radio" name="q1" value="A" required>
                        <span class="option-label">A. Nama pengirim yang dikenali.</span>
                    </label>
                    <!-- Opsi B -->
                    <label class="option-item">
                        <input type="radio" name="q1" value="B">
                        <span class="option-label">B. Alamat emel yang nampak rasmi.</span>
                    </label>
                    <!-- Opsi C (JAWAPAN BETUL) -->
                    <label class="option-item">
                        <input type="radio" name="q1" value="C">
                        <span class="option-label">C. Nada mesej yang mendesak dan meminta tindakan segera.</span>
                    </label>
                    <!-- Opsi D -->
                    <label class="option-item">
                        <input type="radio" name="q1" value="D">
                        <span class="option-label">D. Penggunaan tatabahasa yang sempurna.</span>
                    </label>
                </div>
            </div>

            <div class="d-flex justify-content-center border-top pt-4 mt-5">
                <button type="submit" class="btn btn-dark rounded-pill px-5 fw-bold">Hantar Jawapan</button>
            </div>
        </form>
    </div>
</div>