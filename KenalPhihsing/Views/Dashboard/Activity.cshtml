
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Aktiviti Terkini";
}

<!-- Include Ionicons for the professional look -->
<script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
<script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>

@section Styles {
    <link href="~/Content/Activity.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />
}

<div class="container-fluid py-4" style="background-color: #F9FAFB; min-height: 100vh;">
    <div class="row g-4">

        <!-- BAHAGIAN KIRI: Activity Feed -->
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-end mb-4">
                <div>
                    <h2 class="fw-bold mb-1">Aktiviti Terkini</h2>
                    <p class="text-muted">Jejaki setiap langkah kejayaan anda di sini.</p>
                </div>

                <!-- Daily Streak Widget -->
                <div class="streak-badge d-flex align-items-center gap-3 p-2 px-3 rounded-4 shadow-sm bg-white border border-warning">
                    <div class="streak-icon-box">
                        <ion-icon name="flame" class="text-warning fs-3"></ion-icon>
                    </div>
                    <div>
                        <div class="fw-bold lh-1" style="font-size: 1.1rem;">5 Hari</div>
                        <small class="text-muted fw-bold" style="font-size: 9px; letter-spacing: 1px;">STREAK AKTIF</small>
                    </div>
                </div>
            </div>

            <!-- Filter Pills with Icons -->
            <div class="d-flex gap-2 mb-4 overflow-auto pb-2">
                <button class="btn btn-filter active d-flex align-items-center gap-2">
                    <ion-icon name="apps-outline"></ion-icon> Semua
                </button>
                <button class="btn btn-filter d-flex align-items-center gap-2">
                    <ion-icon name="ribbon-outline"></ion-icon> Pencapaian
                </button>
                <button class="btn btn-filter d-flex align-items-center gap-2">
                    <ion-icon name="rocket-outline"></ion-icon> Simulasi
                </button>
                <button class="btn btn-filter d-flex align-items-center gap-2">
                    <ion-icon name="alert-circle-outline"></ion-icon> Amaran
                </button>
            </div>

            <div class="activity-feed">
                <!-- Activity: Sijil -->
                <div class="activity-card glass-card card-sijil p-4 mb-3 d-flex align-items-center gap-4">
                    <div class="activity-icon-circle icon-sijil shadow-sm">
                        <ion-icon name="ribbon"></ion-icon>
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between">
                            <span class="badge-time mb-2"><ion-icon name="time-outline"></ion-icon> Baru Sahaja</span>
                        </div>
                        <h6 class="fw-bold mb-1">Sijil "Wira Siber" Diperoleh!</h6>
                        <p class="small text-muted mb-0">Tahniah! Modul <strong>Asas Phishing</strong> telah selesai.</p>
                        <div class="mt-3">
                            <a href="#" class="btn btn-action-sijil btn-sm rounded-pill px-4 d-inline-flex align-items-center gap-2">
                                <ion-icon name="eye-outline"></ion-icon> Lihat Sijil
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Activity: Amaran -->
                <div class="activity-card glass-card card-amaran p-4 mb-3 d-flex align-items-center gap-4">
                    <div class="activity-icon-circle icon-amaran shadow-sm">
                        <ion-icon name="shield-half-outline"></ion-icon>
                    </div>
                    <div class="flex-grow-1">
                        <span class="badge-time mb-2"><ion-icon name="time-outline"></ion-icon> 2 Jam Lepas</span>
                        <h6 class="fw-bold mb-1">Amaran: Taktik SMS Scam Baru</h6>
                        <p class="small text-muted mb-0">Kami mengesan taktik penipuan baru melibatkan pautan bank palsu.</p>
                        <div class="mt-3">
                            <a href="#" class="btn btn-action-amaran btn-sm rounded-pill px-4 d-inline-flex align-items-center gap-2">
                                <ion-icon name="book-outline"></ion-icon> Baca Info
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Activity: Simulasi -->
                <div class="activity-card glass-card card-simulasi p-4 mb-3 d-flex align-items-center gap-4">
                    <div class="activity-icon-circle icon-simulasi shadow-sm">
                        <ion-icon name="game-controller"></ion-icon>
                    </div>
                    <div class="flex-grow-1">
                        <span class="badge-time mb-2"><ion-icon name="time-outline"></ion-icon> Semalam</span>
                        <h6 class="fw-bold mb-1">Misi Mingguan Sedia!</h6>
                        <p class="small text-muted mb-2">Simulasi "Emel Hadiah Misteri" sedang menunggu anda.</p>
                        <div class="mt-3">
                            <a href="#" class="btn btn-action-simulasi btn-sm rounded-pill px-4 d-inline-flex align-items-center gap-2">
                                <ion-icon name="play-outline"></ion-icon> Mula Misi
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Load More Interaction -->
            <div class="text-center mt-5">
                <button class="btn btn-outline-dark rounded-pill px-5 py-2 fw-bold d-inline-flex align-items-center gap-2">
                    <ion-icon name="chevron-down-outline"></ion-icon> Muat Aktiviti Terdahulu
                </button>
            </div>
        </div>

        <!-- BAHAGIAN KANAN: Engagement Zone -->
        <div class="col-lg-4">

            <!-- Heatmap Calendar -->
            <div class="glass-card p-4 mb-4 shadow-sm border-0">
                <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                    <ion-icon name="calendar-outline" class="text-primary"></ion-icon>
                    Konsistensi Latihan
                </h6>
                <div class="heatmap-container">
                    <div class="d-flex flex-wrap gap-1">
                        @for (int i = 0; i < 28; i++)
                        {
                            <div class="heatmap-sq @(i % 4 == 0 ? "level-3" : (i % 6 == 0 ? "level-1" : "level-0"))"></div>
                        }
                    </div>
                    <div class="d-flex justify-content-between mt-2">
                        <small class="text-muted" style="font-size: 10px;">Malas</small>
                        <small class="text-muted" style="font-size: 10px;">Rajin!</small>
                    </div>
                </div>
            </div>

            <!-- Progress Circles -->
            <div class="glass-card p-4 mb-4 shadow-sm border-0">
                <h6 class="fw-bold mb-4 d-flex align-items-center gap-2">
                    <ion-icon name="pie-chart-outline" class="text-primary"></ion-icon>
                    Ringkasan Pencapaian
                </h6>
                <div class="d-flex justify-content-around text-center">
                    <div class="progress-group">
                        <div class="circular-progress" style="--percent: 75; --color: #10B981;">
                            <ion-icon name="school-outline" class="progress-inner-icon"></ion-icon>
                        </div>
                        <small class="d-block mt-2 fw-bold">3/4 Sijil</small>
                    </div>
                    <div class="progress-group">
                        <div class="circular-progress" style="--percent: 40; --color: #3B82F6;">
                            <ion-icon name="book-outline" class="progress-inner-icon"></ion-icon>
                        </div>
                        <small class="d-block mt-2 fw-bold">2/5 Modul</small>
                    </div>
                </div>
            </div>

            <!-- Hero Spotlight -->
            <div class="hero-card p-4 shadow-sm text-white text-center position-relative overflow-hidden">
                <div class="hero-bg-glow"></div>
                <ion-icon name="trophy" class="hero-trophy-icon"></ion-icon>
                <h6 class="fw-bold mb-1">Wira Minggu Ini</h6>
                <div class="avatar-box my-3">
                    <img src="https://ui-avatars.com/api/?name=Adam+Siber&background=random" class="rounded-circle border border-3 border-white shadow" width="60" />
                </div>
                <p class="small mb-0 opacity-75">Syabas, <strong>Adam!</strong></p>
                <p style="font-size: 11px;">Anda mendahului 85% rakan lain.</p>
            </div>
        </div>
    </div>
</div>

<style>
    /* Modern Color Palette */
    :root {
        --success-green: #10B981;
        --warning-red: #EF4444;
        --action-blue: #3B82F6;
    }

    /* Glassmorphism Effect */
    .glass-card {
        background: #ffffff;
        border-radius: 24px;
        border: 1px solid rgba(0,0,0,0.04);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .activity-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important;
    }

    /* Activity Styling */
    .card-sijil {
        border-left: 6px solid var(--success-green);
    }

    .card-amaran {
        border-left: 6px solid var(--warning-red);
    }

    .card-simulasi {
        border-left: 6px solid var(--action-blue);
    }

    .activity-icon-circle {
        width: 55px;
        height: 55px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
    }

    .icon-sijil {
        background: #ECFDF5;
        color: var(--success-green);
    }

    .icon-amaran {
        background: #FEF2F2;
        color: var(--warning-red);
    }

    .icon-simulasi {
        background: #EFF6FF;
        color: var(--action-blue);
    }

    /* Filter Pills */
    .btn-filter {
        background: white;
        border: 1px solid #eee;
        border-radius: 50px;
        padding: 10px 22px;
        font-weight: 600;
        color: #555;
        transition: 0.3s;
    }

        .btn-filter.active, .btn-filter:hover {
            background: #111;
            color: white;
            border-color: #111;
        }

    /* Badge Time */
    .badge-time {
        background: #f1f3f5;
        color: #666;
        font-size: 10px;
        font-weight: 800;
        padding: 5px 12px;
        border-radius: 50px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    /* Progress Circles */
    .circular-progress {
        width: 65px;
        height: 65px;
        border-radius: 50%;
        background: radial-gradient(closest-side, white 79%, transparent 80% 100%), conic-gradient(var(--color) calc(var(--percent) * 1%), #f0f0f0 0);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .progress-inner-icon {
        font-size: 20px;
        color: var(--color);
    }

    /* Heatmap */
    .heatmap-sq {
        width: 15px;
        height: 15px;
        border-radius: 3px;
    }

    .level-0 {
        background: #f0f0f0;
    }

    .level-1 {
        background: #d1fae5;
    }

    .level-3 {
        background: #10b981;
    }

    /* Hero Spotlight */
    .hero-card {
        background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        border-radius: 24px;
    }

    .hero-trophy-icon {
        position: absolute;
        right: -10px;
        top: -10px;
        font-size: 80px;
        opacity: 0.1;
        transform: rotate(15deg);
    }

    /* Button Glows */
    .btn-action-sijil {
        background: var(--success-green);
        color: white;
        border: none;
    }

    .btn-action-amaran {
        background: var(--warning-red);
        color: white;
        border: none;
    }

    .btn-action-simulasi {
        background: var(--action-blue);
        color: white;
        border: none;
    }
</style>