@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Keputusan Kuiz";
    bool isCorrect = ViewBag.IsCorrect ?? false;
}

@section Styles {
    <link href="~/Content/Quiz.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/Dashboard.css" rel="stylesheet" type="text/css" />
}

<div class="result-container text-center">
    <div class="result-card p-5 shadow-lg">
        <!-- IKON BERUBAH IKUT KEPUTUSAN -->
        <div class="mb-3">
            <ion-icon name="@ViewBag.Icon" class="display-1 @ViewBag.ColorClass"></ion-icon>
        </div>

        <h2 class="fw-bold mb-4">
            <span class="@ViewBag.ColorClass">@ViewBag.Message</span>
        </h2>

        <p class="text-muted small mb-5">
            @(isCorrect ? "Anda kini lebih bersedia untuk mengenal pasti ancaman phishing." : "Sila baca semula modul untuk memahami tanda-tanda phishing.")
        </p>

        <div class="row g-4 mb-5 text-start">
            <div class="col-md-6">
                <div class="stat-summary-card p-4 h-100">
                    <h6 class="fw-bold mb-4 border-bottom pb-2">Pencapaian Anda</h6>
                    <div class="d-flex align-items-center mb-3">
                        <ion-icon name="star" class="text-warning me-3"></ion-icon>
                        <span class="small fw-bold">Skor Akhir: <span class="@ViewBag.ColorClass">@ViewBag.Score%</span></span>
                    </div>
                    <div class="d-flex align-items-center mb-3">
                        <ion-icon name="heart" class="text-danger me-3"></ion-icon>
                        <span class="small">Nyawa Berbaki: @(isCorrect ? "🧡🧡🧡" : "🧡")</span>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="tips-summary-card p-4 h-100">
                    @if (isCorrect)
                    {
                        <h6 class="fw-bold mb-4 border-bottom pb-2 text-success">Cemerlang!</h6>
                        <p class="small">Anda berjaya mengesan taktik 'Urgency' yang digunakan oleh scammer.</p>
                    }
                    else
                    {
                        <h6 class="fw-bold mb-4 border-bottom pb-2 text-danger">Tips Pemulihan:</h6>
                        <p class="small">Ingat, bank tidak akan pernah mendesak anda melakukan tindakan segera melalui emel yang tidak dikenali.</p>
                    }
                </div>
            </div>
        </div>

        <div class="result-actions d-flex justify-content-center gap-3">
            <a href="@Url.Action("Quiz", "Dashboard")" class="btn btn-outline-dark rounded-pill px-4">Ulang lagi</a>
            <a href="@Url.Action("Index", "Dashboard")" class="btn btn-dark rounded-pill px-4">Dashboard</a>
        </div>
    </div>
</div>