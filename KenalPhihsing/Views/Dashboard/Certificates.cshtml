@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Senarai Sijil";
}

@section Styles {
    <link href="~/Content/Certificates.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/Dashboard.css" rel="stylesheet" type="text/css" />
}

<div class="container-fluid">
    <div class="mb-5">
        <h2 class="fw-bold">Senarai Sijil Anda</h2>
        <p class="text-muted">Lihat semua sijil pencapaian yang telah anda perolehi.</p>
    </div>

    <!-- Sijil 1 -->
    <div class="cert-item-card p-4 mb-3 d-flex align-items-center gap-4 shadow-sm">
        <div class="cert-icon-box bg-gold-gradient">
            <ion-icon name="ribbon-outline"></ion-icon>
        </div>
        <div class="flex-grow-1">
            <h5 class="fw-bold mb-1">Sijil Asas Phishing</h5>
            <p class="small text-muted mb-0">Diterbitkan: 11 Januari 2025 | Skor: 100%</p>
            <a href="#" class="extra-small text-primary text-decoration-none">Lihat Arkib</a>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("CertificateDetail", "Dashboard")" class="btn btn-dark rounded-pill px-4 btn-sm">Lihat Sijil</a>
            <button class="btn btn-outline-dark rounded-pill px-3 btn-sm" onclick="showPopup('Muat Turun Selesai')">
                <ion-icon name="download-outline"></ion-icon>
            </button>
        </div>
    </div>

    <!-- Sijil 2 (Lock/Belum Selesai) -->
    <div class="cert-item-card p-4 mb-3 d-flex align-items-center gap-4 opacity-50">
        <div class="cert-icon-box bg-secondary">
            <ion-icon name="lock-closed-outline"></ion-icon>
        </div>
        <div class="flex-grow-1">
            <h5 class="fw-bold mb-1">Sijil Taktik Psikologi</h5>
            <p class="small text-muted mb-0">Status: Belum Selesai</p>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        function showPopup(text) {
            var myModal = new bootstrap.Modal(document.getElementById('certActionModal'));
            document.getElementById('actionText').innerText = text;
            myModal.show();
        }
    </script>
}