@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Tetapan";
}

@section Styles {
    <link href="~/Content/Settings.css" rel="stylesheet" type="text/css" />
}

<div class="settings-container">
    <h2 class="fw-bold mb-4">Tetapan</h2>

    <div class="row g-4">
        <!-- Kolum Kiri -->
        <div class="col-lg-6">
            <!-- Info Peribadi -->
            <div class="settings-card p-4 mb-4 shadow-sm">
                <h6 class="fw-bold mb-3">Info Peribadi</h6>
                <div class="mb-3">
                    <label class="form-label small">Nama</label>
                    <input type="text" class="form-control settings-input" value="@ViewBag.UserName">
                </div>
                <div class="mb-2">
                    <label class="form-label small">E-mail</label>
                    <input type="email" class="form-control settings-input" value="@ViewBag.UserEmail">
                </div>
            </div>

            <!-- Kata Laluan (KINI DENGAN FUNGSI SHOW PASSWORD) -->
            <div class="settings-card p-4 shadow-sm">
                <h6 class="fw-bold mb-3">Kata Laluan</h6>

                <!-- Kata Laluan Semasa -->
                <div class="mb-3">
                    <label class="form-label small">Kata Laluan Semasa</label>
                    <div class="password-wrapper">
                        <input type="password" id="currentPwd" class="form-control settings-input" placeholder="••••••••">
                        <button type="button" class="toggle-password" onclick="togglePassword('currentPwd', 'iconCurrent')">
                            <ion-icon id="iconCurrent" name="eye-outline"></ion-icon>
                        </button>
                    </div>
                </div>

                <!-- Kata Laluan Baharu -->
                <div class="mb-3">
                    <label class="form-label small">Kata Laluan Baharu</label>
                    <div class="password-wrapper">
                        <input type="password" id="newPwd" class="form-control settings-input" placeholder="Sila Masukkan Kata Laluan Baharu">
                        <button type="button" class="toggle-password" onclick="togglePassword('newPwd', 'iconNew')">
                            <ion-icon id="iconNew" name="eye-outline"></ion-icon>
                        </button>
                    </div>
                </div>

                <button class="btn btn-dark rounded-pill px-4 mt-2" data-bs-toggle="modal" data-bs-target="#passwordModal">
                    Simpan Kata Laluan
                </button>
            </div>
        </div>

        <!-- Kolum Kanan -->
        <div class="col-lg-6">
            <!-- Notifikasi -->
            <div class="settings-card p-4 mb-4 shadow-sm">
                <h6 class="fw-bold mb-3">Notifikasi</h6>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="small">Emel</span>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" checked>
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="small">Maklumat Notifikasi</span>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox">
                    </div>
                </div>
            </div>

            <!-- Aksi -->
            <div class="settings-card p-4 shadow-sm">
                <h6 class="fw-bold mb-3">Aksi</h6>
                <p class="extra-small text-muted mb-3">Padamkan akaun anda secara kekal. Data anda tidak boleh dikembalikan selepas ini.</p>
                <button class="btn btn-danger rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#deleteModal">
                    Padam Akaun
                </button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL: Kata Laluan Berjaya (input_file_4 - Setting Password) -->
<div class="modal fade" id="passwordModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-5 border-0 shadow-lg modal-custom">
            <div class="modal-body">
                <h5 class="fw-bold mb-4">Kata Laluan Baharu Disimpan</h5>
                <button type="button" class="btn btn-dark rounded-pill px-5" data-bs-dismiss="modal">Baik</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL: Akaun Dipadam (input_file_4 - Account) -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-5 border-0 shadow-lg modal-custom">
            <div class="modal-body">
                <h5 class="fw-bold mb-4 text-danger">Akaun Anda telah Dipadamkan</h5>
                <a href="@Url.Action("Index", "Home")" class="btn btn-dark rounded-pill px-5">Baik</a>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        function togglePassword(inputId, iconId) {
            // 1. Ambil input berdasarkan ID yang dihantar (currentPwd atau newPwd)
            var passwordInput = document.getElementById(inputId);

            // 2. Ambil icon berdasarkan ID yang dihantar (iconCurrent atau iconNew)
            var icon = document.getElementById(iconId);

            // Debugging: Lihat di Console (F12) jika function ini dipanggil
            console.log("Menukar paparan untuk: " + inputId);

            if (passwordInput.type === "password") {
                passwordInput.type = "text"; // Tunjukkan password
                icon.setAttribute("name", "eye-off-outline"); // Tukar ikon ke mata pangkah
            } else {
                passwordInput.type = "password"; // Sembunyikan password
                icon.setAttribute("name", "eye-outline"); // Tukar ikon ke mata biasa
            }
        }
    </script>
}