<!-- Inside User Dashboard -->
@{
    var settings = new KenalPhihsing.Data.ApplicationDbContext().SystemSettings.FirstOrDefault();
}

@if (settings != null && !string.IsNullOrEmpty(settings.GlobalAnnouncement))
{
    <div class="alert alert-info">
        @settings.GlobalAnnouncement
    </div>
}

<style>
    /* 1. Main Styles */
    .dashboard-adult .card {
        border-radius: 1.25rem;
        border: 1px solid #f0f0f0;
        transition: transform 0.2s ease;
    }

    /* 2. Welcome Card */
    .welcome-card {
        border-left: 6px solid #006aff !important;
        background: white;
    }

    .shield-badge {
        width: 140px;
        height: 140px;
        background: #006aff;
        clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: white;
        box-shadow: 0 10px 20px rgba(0, 106, 255, 0.2);
    }

    /* 3. Stat Icons */
    .stat-icon {
        width: 45px;
        height: 45px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .bg-soft-warning {
        background: #fff8e6;
        color: #ffb800;
    }

    .bg-soft-primary {
        background: #e6f0ff;
        color: #006aff;
    }

    .bg-soft-danger {
        background: #ffebeb;
        color: #ff4d4d;
    }

    /* 4. Timeline */
    .timeline {
        position: relative;
        padding-left: 30px;
    }

        .timeline::before {
            content: '';
            position: absolute;
            left: 9px;
            top: 10px;
            bottom: 10px;
            width: 1px;
            background: #e0e0e0;
        }

    .timeline-item {
        position: relative;
        margin-bottom: 25px;
    }

    .timeline-dot {
        position: absolute;
        left: -30px;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: white;
        border: 2px solid #006aff;
        z-index: 1;
    }

    /* 5. Chart Bars */
    .chart-container {
        height: 200px;
        display: flex;
        align-items: flex-end;
        justify-content: space-around;
        padding-bottom: 20px;
        border-bottom: 1px dashed #eee;
    }

    .bar {
        width: 60px;
        border-radius: 8px 8px 0 0;
        transition: opacity 0.3s;
    }

        .bar:hover {
            opacity: 0.8;
        }
</style>

<div class="dashboard-adult container-fluid">
    <div class="row g-4">
        <!-- LEFT COLUMN -->
        <div class="col-lg-8">

            <!-- Welcome Header -->
            <div class="welcome-card card p-5 shadow-sm mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="flex-grow-1">
                        <h5 class="text-primary fw-bold mb-0">Selamat Kembali,</h5>
                        <h1 class="fw-bold mb-3">@Session["UserName"]</h1>
                        <p class="text-muted mb-4 w-75">
                            Status Latihan: <b>40% Selesai</b>. Tingkatkan skor kesedaran anda dengan menyelesaikan modul seterusnya.
                        </p>
                        <div class="d-flex gap-3">
                            <a href="@Url.Action("Modules", "Dashboard")" class="btn btn-primary rounded-pill px-4 py-2 fw-bold d-flex align-items-center gap-2 shadow">
                                <ion-icon name="play-circle" class="fs-5"></ion-icon> Sambung Belajar
                            </a>
                            <a href="@Url.Action("ReportScam", "Dashboard")" class="btn btn-outline-danger rounded-pill px-4 py-2 fw-bold">
                                Lapor Ancaman
                            </a>
                        </div>
                    </div>
                    <div class="d-none d-md-block">
                        <div class="shield-badge">
                            <ion-icon name="checkmark-done-outline" style="font-size: 3rem;"></ion-icon>
                            <span class="fw-bold mt-1">Tahap</span>
                            <small>Sederhana</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats Grid -->
            <div class="row g-4 mb-4">
                <div class="col-md-4">
                    <div class="card p-4 shadow-sm h-100 bg-white">
                        <div class="stat-icon bg-soft-warning mb-3">
                            <ion-icon name="medal" class="fs-4"></ion-icon>
                        </div>
                        <h2 class="fw-bold mb-0">85%</h2>
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 10px; letter-spacing: 1px;">Skor Kesedaran</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card p-4 shadow-sm h-100 bg-white">
                        <div class="stat-icon bg-soft-primary mb-3">
                            <ion-icon name="book" class="fs-4"></ion-icon>
                        </div>
                        <h2 class="fw-bold mb-0">2 / 5</h2>
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 10px; letter-spacing: 1px;">Modul Selesai</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card p-4 shadow-sm h-100 bg-white">
                        <div class="stat-icon bg-soft-danger mb-3">
                            <ion-icon name="alert-circle" class="fs-4"></ion-icon>
                        </div>
                        <h2 class="fw-bold mb-0">0</h2>
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 10px; letter-spacing: 1px;">Laporan Aktif</small>
                    </div>
                </div>
            </div>

            <!-- Chart Section -->
            <div class="card p-4 shadow-sm bg-white">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h6 class="fw-bold m-0">Trend Prestasi Kesedaran</h6>
                        <small class="text-muted">Berdasarkan markah kuiz bulanan</small>
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-sm btn-light border dropdown-toggle" type="button">
                            <ion-icon name="calendar-outline" class="align-middle me-1"></ion-icon> 30 Hari Terakhir
                        </button>
                    </div>
                </div>

                <div class="chart-container px-3">
                    <div class="bar" style="height: 40%; background: #cce0ff;"></div>
                    <div class="bar" style="height: 65%; background: #80b3ff;"></div>
                    <div class="bar" style="height: 45%; background: #cce0ff;"></div>
                    <div class="bar" style="height: 85%; background: #3385ff;"></div>
                    <div class="bar" style="height: 100%; background: #006aff;"></div>
                    <div class="bar" style="height: 75%; background: #80b3ff;"></div>
                </div>
                <div class="d-flex justify-content-between mt-3 text-muted" style="font-size: 11px;">
                    <span>Minggu 1</span>
                    <span>Minggu 2</span>
                    <span>Minggu 3</span>
                    <span>Minggu 4</span>
                </div>
            </div>
        </div>

        <!-- RIGHT COLUMN -->
        <div class="col-lg-4">

            <!-- Activity Log -->
            <div class="card p-4 shadow-sm bg-white mb-4">
                <h6 class="fw-bold mb-4 d-flex align-items-center">
                    <ion-icon name="time-outline" class="me-2 text-primary"></ion-icon> Log Aktiviti
                </h6>
                <div class="timeline">
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <p class="small fw-bold mb-0">Modul 2 Selesai</p>
                        <small class="text-muted">Diberi pada 12 Jan 2025 • 09:15 AM</small>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-dot" style="border-color: #ffc107;"></div>
                        <p class="small fw-bold mb-0">Tukar Kata Laluan</p>
                        <small class="text-muted">11 Jan 2025 • 04:30 PM</small>
                    </div>
                    <div class="timeline-item mb-0">
                        <div class="timeline-dot" style="border-color: #28a745;"></div>
                        <p class="small fw-bold mb-0">Pendaftaran Berjaya</p>
                        <small class="text-muted">10 Jan 2025 • 10:00 AM</small>
                    </div>
                </div>
                <button class="btn btn-light btn-sm w-100 mt-4 rounded-pill fw-bold text-muted py-2">Lihat Semua Aktiviti</button>
            </div>

            <!-- Info Box -->
            <div class="card p-4 shadow-sm bg-dark text-white border-0">
                <h6 class="fw-bold mb-3 d-flex align-items-center text-warning">
                    <ion-icon name="shield-half-outline" class="me-2"></ion-icon> Info Keselamatan
                </h6>
                <p class="small opacity-75 mb-4">
                    Peringatan: Pihak bank tidak akan sesekali meminta kata laluan anda melalui SMS atau panggilan telefon.
                </p>
                <hr class="opacity-25 mb-3">
                <a href="#" class="text-warning text-decoration-none small fw-bold">Ketahu lebih lanjut →</a>
            </div>

        </div>
    </div>
</div>