@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Belajar Modul";
}

@section Styles {
    <link href="~/Content/Study.cshtml.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/Dashboard.css" rel="stylesheet" type="text/css" />
}

<div class="study-container py-4">
    <!-- Breadcrumb (Navigasi Kecil) -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Modules", "Dashboard")">Katalog</a></li>
            <li class="breadcrumb-item active">@ViewBag.ModuleTitle</li>
        </ol>
    </nav>

    <!-- Kertas Kandungan -->
    <div class="study-paper shadow-sm">
        <div class="study-header border-bottom p-5">
            <h1 class="fw-bold">@ViewBag.ModuleTitle</h1>
            <p class="text-muted">Topik 1: Apa itu Phishing?</p>
        </div>

        <div class="study-body p-5">
            <div class="content-text fs-5">
                <p>Phishing adalah salah satu teknik penipuan siber yang paling berkesan dan biasa digunakan oleh penjenayah untuk mendapatkan maklumat sensitif anda.</p>

                <h4 class="fw-bold mt-5 mb-3">Bagaimana ia berfungsi?</h4>
                <p>Penipu akan menghantar mesej (emel, SMS, atau panggilan) yang menyamar sebagai pihak berkuasa seperti bank, pejabat pos, atau syarikat kerajaan.</p>

                <!-- Gambar/Visual Analisis -->
                <div class="study-visual-box my-5 p-4 rounded-4 text-center">
                    <div class="placeholder-img bg-light border rounded-3 mb-3" style="height: 300px;">
                        <p class="pt-5 mt-5 text-muted">[ Visual: Contoh Emel Palsu vs Benar ]</p>
                    </div>
                    <p class="small text-muted italic">Rajah 1.1: Contoh taktik pancingan data melalui emel.</p>
                </div>

                <p>Tujuannya adalah untuk mendesak anda klik pada pautan (link) palsu atau memuat turun fail yang mengandungi virus.</p>
            </div>
        </div>

        <!-- Navigasi Bawah -->
        <div class="study-footer p-4 border-top d-flex justify-content-between align-items-center">
            <a href="@Url.Action("Modules", "Dashboard")" class="btn btn-outline-dark rounded-pill px-4">
                <ion-icon name="arrow-back-outline" class="align-middle me-2"></ion-icon> Kembali ke Katalog
            </a>

            <div class="page-indicator small fw-bold">Halaman 1 / 5</div>

            <a href="@Url.Action("ActivitySelection", "Dashboard")" class="btn btn-dark rounded-pill px-5 fw-bold">
                Seterusnya <ion-icon name="arrow-forward-outline" class="align-middle ms-2"></ion-icon>
            </a>
        </div>
    </div>
</div>