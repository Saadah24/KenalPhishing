<!-- Inside User Dashboard -->
@{
    var settings = new KenalPhihsing.Data.ApplicationDbContext().SystemSettings.FirstOrDefault();
}

@if (settings != null && !string.IsNullOrEmpty(settings.GlobalAnnouncement))
{
    <div class="alert alert-info">
        @settings.GlobalAnnouncement
    </div>
}

<style>
    /* Gamified Hover Effects */
    .mission-item {
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        border: 2px solid transparent !important;
    }

        .mission-item:hover {
            transform: scale(1.02);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
            border-color: #00b0ff !important;
            background-color: #ffffff !important;
        }

    .icon-box {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 18px;
        flex-shrink: 0;
    }

    .badge-locked {
        filter: grayscale(100%) blur(1px);
        opacity: 0.3;
    }

    .xp-progress-container {
        background: rgba(255, 255, 255, 0.2);
        height: 20px;
        border-radius: 50px;
        padding: 3px;
    }

    .pulse-icon {
        animation: pulse-animation 2s infinite;
    }

    @@keyframes pulse-animation {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.1);
        }

        100% {
            transform: scale(1);
        }
    }
</style>

<div class="row g-4">
    <!-- 1. HERO HEADER: MISSION CONTROL -->
    <div class="col-12">
        <div class="p-5 mb-2 shadow-lg text-white rounded-5 border-0"
             style="background: linear-gradient(135deg, #00b0ff 0%, #0072ff 100%); position: relative; overflow: hidden;">

            <!-- Decorative Background Icons -->
            <ion-icon name="planet-outline" style="position: absolute; top: 10%; right: 5%; font-size: 10rem; opacity: 0.1; transform: rotate(-20deg);"></ion-icon>
            <ion-icon name="shield-outline" style="position: absolute; bottom: -20px; left: 10%; font-size: 8rem; opacity: 0.1;"></ion-icon>

            <div class="row align-items-center position-relative">
                <div class="col-md-2 text-center d-none d-md-block">
                    <ion-icon name="rocket" class="pulse-icon" style="font-size: 8rem; filter: drop-shadow(0 10px 15px rgba(0,0,0,0.3));"></ion-icon>
                </div>
                <div class="col-md-10">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <ion-icon name="ribbon" class="text-warning fs-3"></ion-icon>
                        <span class="fw-bold text-uppercase" style="letter-spacing: 2px; font-size: 14px;">Misi Aktif: Penjaga Siber</span>
                    </div>
                    <h1 class="fw-bold display-5">Hai, Wira @Session["UserName"]! 🛡️</h1>

                    <!-- XP BAR WITH ICONS -->
                    <div class="mt-4" style="max-width: 600px;">
                        <div class="d-flex justify-content-between mb-2 small fw-bold">
                            <span class="d-flex align-items-center gap-1">
                                <ion-icon name="trending-up" class="fs-5"></ion-icon> Level 2: Wira Muda
                            </span>
                            <span class="d-flex align-items-center gap-1">
                                <ion-icon name="flash" class="text-warning fs-5"></ion-icon> 750 / 1000 XP
                            </span>
                        </div>
                        <div class="xp-progress-container border border-white border-opacity-50">
                            <div class="progress-bar bg-white rounded-pill progress-bar-striped progress-bar-animated" style="width: 75%;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. LEFT SIDEBAR: STATS & RANKING -->
    <div class="col-md-4">
        <!-- Lencana Section -->
        <div class="card p-4 rounded-5 border-0 shadow-sm text-center mb-4" style="background: #FFF9E6;">
            <div class="d-flex align-items-center justify-content-center gap-2 mb-3">
                <ion-icon name="medal" class="text-warning fs-4"></ion-icon>
                <h5 class="fw-bold text-warning m-0">Lencana Koleksi</h5>
            </div>

            <div class="d-flex justify-content-center gap-3 my-2">
                <div title="Wira Pertama" class="icon-circle p-2 bg-white rounded-circle shadow-sm">
                    <ion-icon name="ribbon" class="text-warning" style="font-size: 3rem;"></ion-icon>
                </div>
                <div title="Perisai Siber" class="icon-circle p-2 bg-white rounded-circle shadow-sm">
                    <ion-icon name="shield-checkmark" class="text-primary" style="font-size: 3rem;"></ion-icon>
                </div>
                <div title="Terkunci" class="badge-locked icon-circle p-2 bg-white rounded-circle shadow-sm">
                    <ion-icon name="trophy" class="text-muted" style="font-size: 3rem;"></ion-icon>
                </div>
            </div>

            <div class="mt-4 p-3 rounded-4 bg-white bg-opacity-50 border border-warning border-opacity-25">
                <p class="small fw-bold mb-0 text-muted">
                    <ion-icon name="lock-open-outline" class="align-middle me-1"></ion-icon> Selesaikan 1 misi lagi untuk Trofi!
                </p>
            </div>
        </div>

        <!-- Leaderboard Section -->
        <div class="card p-4 rounded-5 border-0 shadow-sm" style="background: #f8fbff;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="fw-bold m-0 d-flex align-items-center">
                    <ion-icon name="podium-outline" class="me-2 text-primary fs-4"></ion-icon> Top Wira
                </h6>
                <ion-icon name="people-circle-outline" class="fs-4 text-muted"></ion-icon>
            </div>

            <div class="leaderboard-item d-flex align-items-center p-3 mb-2 rounded-4 bg-white shadow-sm border border-light">
                <ion-icon name="star" class="text-warning me-3 fs-4"></ion-icon>
                <div class="flex-grow-1">
                    <span class="d-block small fw-bold">Adam Razak</span>
                    <small class="text-muted">Level 5</small>
                </div>
                <div class="text-end">
                    <span class="badge bg-primary rounded-pill">2.4k XP</span>
                </div>
            </div>

            <div class="leaderboard-item d-flex align-items-center p-3 mb-2 rounded-4">
                <ion-icon name="star-outline" class="text-muted me-3 fs-4"></ion-icon>
                <div class="flex-grow-1">
                    <span class="d-block small fw-bold">Siti Aminah</span>
                    <small class="text-muted">Level 4</small>
                </div>
                <div class="text-end">
                    <span class="badge bg-light text-dark rounded-pill">1.8k XP</span>
                </div>
            </div>
        </div>
    </div>

    <!-- 3. MAIN AREA: MISSION MAP -->
    <div class="col-md-8">
        <div class="card p-4 rounded-5 border-0 shadow-sm h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold m-0 d-flex align-items-center">
                    <ion-icon name="map" class="me-2 text-primary fs-3"></ion-icon> Peta Misi Utama
                </h5>
                <a href="@Url.Action("Modules", "Dashboard")" class="btn btn-sm btn-light rounded-pill px-3 fw-bold">
                    Semua Modul <ion-icon name="chevron-forward-outline" class="align-middle"></ion-icon>
                </a>
            </div>

            <!-- MISSION 1: COMPLETED -->
            <div class="p-4 bg-light rounded-5 d-flex justify-content-between align-items-center mb-3 mission-item">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-box bg-white text-primary shadow-sm">
                        <ion-icon name="mail-open" style="font-size: 2rem;"></ion-icon>
                    </div>
                    <div>
                        <span class="fw-bold fs-5 d-block text-dark">Kenali Phishing Bot</span>
                        <div class="d-flex gap-2 align-items-center mt-1">
                            <span class="badge bg-success-subtle text-success border border-success border-opacity-25 rounded-pill px-2">Mudah</span>
                            <small class="text-muted d-flex align-items-center gap-1">
                                <ion-icon name="flash-outline"></ion-icon> +50 XP
                            </small>
                        </div>
                    </div>
                </div>
                <div class="text-end">
                    <div class="bg-success text-white rounded-circle d-inline-flex p-2 mb-1 shadow-sm">
                        <ion-icon name="sparkles" class="fs-5"></ion-icon>
                    </div>
                    <small class="d-block fw-bold text-success">SIAP</small>
                </div>
            </div>

            <!-- MISSION 2: ACTIVE -->
            <div class="p-4 bg-light rounded-5 d-flex justify-content-between align-items-center mb-3 mission-item border-start border-primary border-5">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-box bg-white text-warning shadow-sm">
                        <ion-icon name="keypad" style="font-size: 2rem;"></ion-icon>
                    </div>
                    <div>
                        <span class="fw-bold fs-5 d-block text-dark">Rahsia Kata Laluan</span>
                        <div class="d-flex gap-2 align-items-center mt-1">
                            <span class="badge bg-warning-subtle text-warning-emphasis border border-warning border-opacity-50 rounded-pill px-2">Sederhana</span>
                            <small class="text-muted d-flex align-items-center gap-1">
                                <ion-icon name="flash-outline"></ion-icon> +150 XP
                            </small>
                        </div>
                    </div>
                </div>
                <a href="@Url.Action("Modules", "Dashboard")" class="btn btn-primary rounded-pill px-4 py-2 fw-bold shadow btn-mula">
                    MULA <ion-icon name="zap" class="ms-1"></ion-icon>
                </a>
            </div>

            <!-- MISSION 3: LOCKED -->
            <div class="p-4 bg-light rounded-5 d-flex justify-content-between align-items-center opacity-50">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-box bg-white text-muted">
                        <ion-icon name="lock-closed" style="font-size: 2rem;"></ion-icon>
                    </div>
                    <div>
                        <span class="fw-bold fs-5 d-block text-muted">Zon Merah: Elak Scam</span>
                        <small class="text-muted d-flex align-items-center gap-1">
                            <ion-icon name="alert-circle-outline"></ion-icon> Selesaikan Misi 2
                        </small>
                    </div>
                </div>
                <ion-icon name="lock-closed-outline" class="fs-2 text-muted"></ion-icon>
            </div>

        </div>
    </div>
</div>