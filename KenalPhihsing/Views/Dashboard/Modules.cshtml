@model IEnumerable<KenalPhihsing.Models.Module>
@section Styles {
    <link href="~/Content/Modules.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/Dashboard.css" rel="stylesheet" type="text/css" />
}

@{
    ViewBag.Title = "Modul Belajar";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    string category = ViewBag.UserCategory ?? Session["UserCategory"]?.ToString() ?? "Adult";
}

<div class="container-fluid py-4">
    <div class="dashboard-page-header mb-5">
        <h2 class="fw-bold">Katalog Modul Pembelajaran</h2>
        <p class="text-muted">Pilih modul untuk kategori <b>@category</b>.</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="module-list">
                @if (Model == null || !Model.Any())
                {
                    <div class="alert alert-info">Admin belum memasukkan sebarang modul untuk kategori ini.</div>
                }
                else
                {
                    <!-- LOOP DINAMIK DARI DATABASE -->
                    foreach (var mod in Model)
                    {
                        <!-- Gunakan mod.ThemeColor yang diset oleh Admin (contoh: #b45309) -->
                        <div class="card mb-3 border-0 shadow-sm" style="border-radius: 15px; border-left: 6px solid @mod.ThemeColor !important;">
                            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white" style="background: @mod.ThemeColor; width: 55px; height: 55px; flex-shrink: 0;">
                                        <ion-icon name="@mod.Icon" style="font-size: 28px;"></ion-icon>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-1" style="color: @mod.ThemeColor">MODUL @mod.ModuleCode</h6>
                                        <h4 class="fw-bold mb-2">@mod.Title</h4>
                                        <p class="text-muted small mb-0">@mod.Description</p>
                                    </div>
                                </div>
                                <a href="@Url.Action("Study", "Dashboard", new { id = mod.Id, page = 1 })"
                                   class="btn rounded-pill px-4 fw-bold text-white shadow-sm" style="background: @mod.ThemeColor">Mula →</a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Kolum Kanan: Status -->
        <div class="col-lg-4">
            <div class="stats-sidebar-card p-4 shadow-sm bg-white rounded-4 border">
                <h6 class="fw-bold text-center">Status Semasa</h6>
                <hr>
                <p class="small text-muted text-center">Selesaikan semua modul untuk mendapatkan lencana <b>Pelajar @category</b>.</p>
                <div class="progress" style="height: 10px;">
                    <div class="progress-bar bg-success" style="width: 20%"></div>
                </div>
            </div>
        </div>
    </div>
</div>