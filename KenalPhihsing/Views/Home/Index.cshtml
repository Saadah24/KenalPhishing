@{
    ViewBag.Title = "Utama";
}

<div class="container py-5">
    <!-- Hero Section (Kekal Sama) -->
    <section class="hero-section row align-items-center mb-5 pb-lg-5 py-xl">
        <div class="col-lg-6 hero-text-container">
            <h1 class="display-3 fw-bold hero-title">Selamat Datang <br> ke KenalPhishing</h1>
            <p class="h4 text-secondary-custom mb-4">Kenal Sebelum Tertipu</p>
            <p class="mb-4 text-light-grey fs-5">
                Belajar Mengenal Pasti Penipuan Phishing Sebelum Terlambat. <br>
                Lindungi diri dan keluarga dari ancaman siber terkini.
            </p>
            <a href="#modul" class="btn btn-hero">Sertai Sekarang <ion-icon name="arrow-forward-outline" class="align-middle ms-2"></ion-icon></a>
        </div>
        <div class="col-lg-6 mt-5 mt-lg-0">
            <div class="hero-visual-box shadow-lg">
                <div class="monitor-frame">
                    <ion-icon name="shield-checkmark-outline" class="hero-main-icon"></ion-icon>
                </div>
            </div>
        </div>
    </section>

    <hr class="section-divider">

    <!-- Stats Section (Kekal Sama) -->

 
    <section class="stats-section row align-items-center my-5 py-xxl">
        <div class="col-lg-5 text-center">
            <div class="stats-visual-container">
                <ion-icon name="alert-circle-outline" class="stats-alert-icon"></ion-icon>
            </div>
        </div>
        <div class="col-lg-7 ps-lg-5 mt-4 mt-lg-0">
            <h2 class="display-4 fw-bold stat-highlight">RM2.7 BILION LESAP</h2>
            <h4 class="text-secondary-custom mb-4">Rakyat Malaysia Kini Sasaran Utama</h4>
            <p class="lead text-light-grey">
                "Jangan biarkan diri anda menjadi statistik seterusnya. Dalam tempoh 11 bulan pertama tahun 2025, kerugian akibat jenayah siber di Malaysia telah mencatatkan angka rekod tertinggi."
            </p>
        </div>
    </section>

    <hr class="section-divider">

    <!-- Modules Section: SEKARANG DIUBAH KE EXPLORE -->
    <section id="modul" class="text-center my-5 py-xxl">
        <h2 class="display-5 fw-bold mb-5 section-title">Modul Pembelajaran</h2>
        <div class="row g-4">
            <!-- Warga Emas -->
            <div class="col-md-4">
                <div class="module-card card-elder h-100">
                    <ion-icon name="people-outline" class="module-icon"></ion-icon>
                    <h4 class="fw-bold mb-4">Warga Emas</h4>
                    <!-- Pautan ke Explore dengan kategori -->
                    <a href="@Url.Action("Explore", "Learning", new { category = "Elder" })" class="btn btn-black-path">Lihat Modul</a>
                </div>
            </div>
            <!-- Dewasa -->
            <div class="col-md-4">
                <div class="module-card card-adult h-100">
                    <ion-icon name="briefcase-outline" class="module-icon"></ion-icon>
                    <h4 class="fw-bold mb-4">Dewasa</h4>
                    <a href="@Url.Action("Explore", "Learning", new { category = "Adult" })" class="btn btn-black-path">Lihat Modul</a>
                </div>
            </div>
            <!-- Kanak-Kanak -->
            <div class="col-md-4">
                <div class="module-card card-kid h-100">
                    <ion-icon name="game-controller-outline" class="module-icon"></ion-icon>
                    <h4 class="fw-bold mb-4">Kanak-Kanak</h4>
                    <a href="@Url.Action("Explore", "Learning", new { category = "Child" })" class="btn btn-black-path">Lihat Modul</a>
                </div>
            </div>
        </div>
    </section>

    <hr class="section-divider">

    <!-- Why Us (Kekal Sama) -->
    <section class="why-us-section row my-5 py-5 align-items-stretch">
        <div class="col-lg-4 mb-4 mb-lg-0">
            <div class="why-us-summary">
                <h2 class="fw-bold">Kenapa Belajar Dengan Kami?</h2>
            </div>
        </div>
        <div class="col-lg-8 ps-lg-5">
            <p class="text-center text-secondary-custom mb-5 small">Platform interaktif yang direka khusus untuk membasmi penipuan siber.</p>
            <div class="row g-4 text-start">
                <div class="col-md-4 text-center">
                    <div class="feature-icon-container">
                        <ion-icon name="phone-portrait-outline"></ion-icon>
                    </div>
                    <p class="small text-secondary-custom"><strong>Simulasi:</strong> Alami situasi phishing sebenar.</p>
                </div>
                <div class="col-md-4 text-center">
                    <div class="feature-icon-container">
                        <ion-icon name="language-outline"></ion-icon>
                    </div>
                    <p class="small text-secondary-custom"><strong>Bahasa:</strong> Kandungan dalam Bahasa Melayu.</p>
                </div>
                <div class="col-md-4 text-center">
                    <div class="feature-icon-container">
                        <ion-icon name="ribbon-outline"></ion-icon>
                    </div>
                    <p class="small text-secondary-custom"><strong>Sijil:</strong> Pengiktirafan rasmi tamat modul.</p>
                </div>
            </div>
        </div>
    </section>
</div>